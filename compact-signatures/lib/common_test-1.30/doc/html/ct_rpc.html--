          <h4 class="specs-title">Types</h4>

            <pre translate="no">App = <a href="../../../../lib/../erts/doc/html/erlang.html#t:atom/0">atom</a>()</pre>

            <pre translate="no">Candidates = [<a href="../../../../lib/../erts/doc/html/erlang.html#t:node/0">node</a>()]</pre>

