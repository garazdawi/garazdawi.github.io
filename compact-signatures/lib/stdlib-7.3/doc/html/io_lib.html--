    <div class="heading-with-actions">

      <div class="signature-row">

          <h1 class="signature" translate="no">chars_limit()</h1>



          <a href="https://github.com/erlang/otp/blob/master/lib/stdlib/src/io_lib.erl#L204" class="icon-action" rel="help nofollow" aria-label="View Source">
            <i class="ri-code-s-slash-line" aria-hidden="true"></i>
