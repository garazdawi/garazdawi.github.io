</span><span class="p" data-group-id="8254854028-7">[</span><span class="ss">hipe</span><span class="p" data-group-id="8254854028-7">]</span><span class="w"> </span><span class="p" data-group-id="8254854028-8">[</span><span class="ss">kernel</span><span class="o">-</span><span class="nc">poll</span><span class="p">:</span><span class="ss">false</span><span class="p" data-group-id="8254854028-8">]</span><span class="w">
