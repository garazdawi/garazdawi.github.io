  <section class="docstring">



<p>Returns the keys in <code class="inline">Tree</code> as an ordered list.</p><h2 id="keys/1-examples" class="section-heading"><a href="#keys/1-examples" class="hover-link"><i class="ri-link-m" aria-hidden="true"></i></a><span class="text">Examples</span></h2><pre><code class="makeup erlang" translate="no"><span class="gp unselectable">1&gt; </span><span class="n">Tree</span><span class="w"> </span><span class="o">=</span><span class="w"> </span><span class="nc">gb_trees</span><span class="p">:</span><span class="nf">from_orddict</span><span class="p" data-group-id="5252718113-1">(</span><span class="p" data-group-id="5252718113-2">[</span><span class="p" data-group-id="5252718113-3">{</span><span class="ss">a</span><span class="p">,</span><span class="mi">1</span><span class="p" data-group-id="5252718113-3">}</span><span class="p">,</span><span class="p" data-group-id="5252718113-4">{</span><span class="ss">b</span><span class="p">,</span><span class="mi">2</span><span class="p" data-group-id="5252718113-4">}</span><span class="p">,</span><span class="p" data-group-id="5252718113-5">{</span><span class="ss">c</span><span class="p">,</span><span class="mi">3</span><span class="p" data-group-id="5252718113-5">}</span><span class="p" data-group-id="5252718113-2">]</span><span class="p" data-group-id="5252718113-1">)</span><span class="p">.</span><span class="w">
</span><span class="gp unselectable">2&gt; </span><span class="nc">gb_trees</span><span class="p">:</span><span class="nf">keys</span><span class="p" data-group-id="5252718113-6">(</span><span class="n">Tree</span><span class="p" data-group-id="5252718113-6">)</span><span class="p">.</span><span class="w">
</span><span class="p" data-group-id="5252718113-7">[</span><span class="ss">a</span><span class="p">,</span><span class="ss">b</span><span class="p">,</span><span class="ss">c</span><span class="p" data-group-id="5252718113-7">]</span><span class="w">
</span><span class="gp unselectable">3&gt; </span><span class="nc">gb_trees</span><span class="p">:</span><span class="nf">keys</span><span class="p" data-group-id="5252718113-8">(</span><span class="nc">gb_trees</span><span class="p">:</span><span class="nf">empty</span><span class="p" data-group-id="5252718113-9">(</span><span class="p" data-group-id="5252718113-9">)</span><span class="p" data-group-id="5252718113-8">)</span><span class="p">.</span><span class="w">
</span><span class="p" data-group-id="5252718113-10">[</span><span class="p" data-group-id="5252718113-10">]</span></code></pre>
