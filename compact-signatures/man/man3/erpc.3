\fB                           RequestIdCollection ::\fR
\fB                               request_id_collection(),\fR
\fB                           WaitTime :: timeout_time(),\fR
\fB                           Delete :: boolean(),\fR
\fB                           Label :: term(),\fR
\fB                           NewRequestIdCollection ::\fR
\fB                               request_id_collection(),\fR
\fB                           Result :: term().\fR

.br
.RS
.PP
