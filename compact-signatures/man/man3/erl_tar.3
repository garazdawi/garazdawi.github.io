.B
\fBadd_opt() ::\fR
\fB          dereference | verbose |\fR
\fB          {chunks, pos_integer()} |\fR
\fB          {atime, non_neg_integer()} |\fR
\fB          {mtime, non_neg_integer()} |\fR
\fB          {ctime, non_neg_integer()} |\fR
\fB          {mode, non_neg_integer()} |\fR
\fB          {uid, non_neg_integer()} |\fR
\fB          {gid, non_neg_integer()}.\fR

.br
.RS

.RE
.B
\fBcreate_opt() :: compressed | cooked | dereference | verbose.\fR

.br
.RS

.RE
.B
\fBextract_opt() ::\fR
