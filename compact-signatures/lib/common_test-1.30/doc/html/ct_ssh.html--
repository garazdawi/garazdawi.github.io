            <pre translate="no"><span class="attribute">-spec</span> send(SSH, ChannelId, Data, Timeout) -> ok | {error, Reason}
              when
                  SSH :: <a href="#t:connection/0">connection</a>(),
                  ChannelId :: <a href="#t:ssh_channel_id/0">ssh_channel_id</a>(),
                  Data :: <a href="../../../../lib/../erts/doc/html/erlang.html#t:iodata/0">iodata</a>(),
