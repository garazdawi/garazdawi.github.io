<section class="detail" id="update_counter/3">


  <div class="detail-header">
    <a href="#update_counter/3" class="detail-link" data-no-tooltip="" aria-label="Link to this function">
      <i class="ri-link-m" aria-hidden="true"></i>
    </a>
    <div class="heading-with-actions">

      <div class="signature-row">




              <h1 class="signature" translate="no">update_counter(Key, Increment, Orddict1)<span class="signature-arrow">&nbsp;-&gt;&nbsp;</span><span class="signature-result">Orddict2</span></h1>





          <a href="https://github.com/erlang/otp/blob/master/lib/stdlib/src/orddict.erl#L486" class="icon-action" rel="help nofollow" aria-label="View Source">
            <i class="ri-code-s-slash-line" aria-hidden="true"></i>
