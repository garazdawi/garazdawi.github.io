          </span><span class="p" data-group-id="0162458515-389">{</span><span class="ss">excl_app_filters</span><span class="p">,</span><span class="p" data-group-id="0162458515-390">[</span><span class="s">&quot;^ebin/.*\\.appup$&quot;</span><span class="p" data-group-id="0162458515-390">]</span><span class="p" data-group-id="0162458515-389">}</span><span class="p">,</span><span class="w">
