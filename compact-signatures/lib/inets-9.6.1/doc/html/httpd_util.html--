<div id="top-content">
  <div class="heading-with-actions top-heading">
    <h1>
      <span translate="no">httpd_util</span> 
      <small class="app-vsn" translate="no">(inets v9.6.1)</small>

    </h1>

<a href="httpd_util.md" title="Copy Markdown (hold Ctrl/Cmd and click it to open as Markdown)" class="copy-markdown icon-action" rel="help">
  <i class="ri-markdown-line" aria-hidden="true"></i>
  <span class="sr-only">Copy Markdown</span>
