      <i class="ri-link-m" aria-hidden="true"></i>
    </a>
    <div class="heading-with-actions">

        <div class="signature-row">
          <h1 class="signature" translate="no">rfc1123_date()<span class="signature-arrow">&nbsp;≡&nbsp;</span><span class="signature-result">rfc1123_date/1</span></h1>


            <a href="https://github.com/erlang/otp/blob/master/lib/inets/src/http_server/httpd_util.erl#L469" class="icon-action" rel="help nofollow" aria-label="View Source">
              <i class="ri-code-s-slash-line" aria-hidden="true"></i>
            </a>

        </div>

      <div class="signature-row">


            <h1 class="signature" translate="no">rfc1123_date(LocalTime :: <a href="../../../../lib/stdlib/doc/html/calendar.html#t:datetime/0">calendar:datetime</a>() | undefined)<span class="signature-arrow">&nbsp;-&gt;&nbsp;</span><span class="signature-result">RFC1123Date</span></h1>




          <a href="https://github.com/erlang/otp/blob/master/lib/inets/src/http_server/httpd_util.erl#L483" class="icon-action" rel="help nofollow" aria-label="View Source">
