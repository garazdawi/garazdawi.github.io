  <section class="docstring">



<p>Returns <code class="inline">true</code> if <code class="inline">Key</code> is present in <code class="inline">Tree</code>; otherwise, returns
<code class="inline">false</code>.</p><h2 id="is_defined/2-examples" class="section-heading"><a href="#is_defined/2-examples" class="hover-link"><i class="ri-link-m" aria-hidden="true"></i></a><span class="text">Examples</span></h2><pre><code class="makeup erlang" translate="no"><span class="gp unselectable">1&gt; </span><span class="n">Tree</span><span class="w"> </span><span class="o">=</span><span class="w"> </span><span class="nc">gb_trees</span><span class="p">:</span><span class="nf">from_orddict</span><span class="p" data-group-id="1588144913-1">(</span><span class="p" data-group-id="1588144913-2">[</span><span class="p" data-group-id="1588144913-3">{</span><span class="ss">a</span><span class="p">,</span><span class="mi">1</span><span class="p" data-group-id="1588144913-3">}</span><span class="p">,</span><span class="p" data-group-id="1588144913-4">{</span><span class="ss">b</span><span class="p">,</span><span class="mi">2</span><span class="p" data-group-id="1588144913-4">}</span><span class="p">,</span><span class="p" data-group-id="1588144913-5">{</span><span class="ss">c</span><span class="p">,</span><span class="mi">3</span><span class="p" data-group-id="1588144913-5">}</span><span class="p" data-group-id="1588144913-2">]</span><span class="p" data-group-id="1588144913-1">)</span><span class="p">.</span><span class="w">
</span><span class="gp unselectable">2&gt; </span><span class="nc">gb_trees</span><span class="p">:</span><span class="nf">is_defined</span><span class="p" data-group-id="1588144913-6">(</span><span class="ss">a</span><span class="p">,</span><span class="w"> </span><span class="n">Tree</span><span class="p" data-group-id="1588144913-6">)</span><span class="p">.</span><span class="w">
</span><span class="ss">true</span><span class="w">
</span><span class="gp unselectable">3&gt; </span><span class="nc">gb_trees</span><span class="p">:</span><span class="nf">is_defined</span><span class="p" data-group-id="1588144913-7">(</span><span class="ss">x</span><span class="p">,</span><span class="w"> </span><span class="n">Tree</span><span class="p" data-group-id="1588144913-7">)</span><span class="p">.</span><span class="w">
</span><span class="ss">false</span></code></pre>
