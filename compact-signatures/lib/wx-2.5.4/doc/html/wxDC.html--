<section class="detail" id="setBrush/2">


  <div class="detail-header">
    <a href="#setBrush/2" class="detail-link" data-no-tooltip="" aria-label="Link to this function">
      <i class="ri-link-m" aria-hidden="true"></i>
    </a>
    <div class="heading-with-actions">

