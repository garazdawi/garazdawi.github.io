            <pre translate="no"><span class="attribute">-type</span> format_fun() :: fun((<a href="../../../../lib/../erts/doc/html/erlang.html#t:term/0">term</a>(), <a href="#t:column/0">column</a>()) -> <a href="../../../../lib/../erts/doc/html/erlang.html#t:iolist/0">iolist</a>()).</pre>

