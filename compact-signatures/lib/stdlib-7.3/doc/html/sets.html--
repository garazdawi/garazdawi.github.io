</span><span class="gp unselectable">2&gt; </span><span class="n">S1</span><span class="w"> </span><span class="o">=</span><span class="w"> </span><span class="nc">sets</span><span class="p">:</span><span class="nf">add_element</span><span class="p" data-group-id="4895589493-2">(</span><span class="mi">7</span><span class="p">,</span><span class="w"> </span><span class="n">S0</span><span class="p" data-group-id="4895589493-2">)</span><span class="p">.</span><span class="w">
</span><span class="gp unselectable">3&gt; </span><span class="nc">sets</span><span class="p">:</span><span class="nf">to_list</span><span class="p" data-group-id="4895589493-3">(</span><span class="n">S1</span><span class="p" data-group-id="4895589493-3">)</span><span class="p">.</span><span class="w">
</span><span class="p" data-group-id="4895589493-4">[</span><span class="mi">7</span><span class="p" data-group-id="4895589493-4">]</span><span class="w">
