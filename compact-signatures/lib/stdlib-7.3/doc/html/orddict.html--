</span><span class="gp unselectable">2&gt; </span><span class="nc">orddict</span><span class="p">:</span><span class="nf">fetch_keys</span><span class="p" data-group-id="8250066760-8">(</span><span class="n">OrdDict1</span><span class="p" data-group-id="8250066760-8">)</span><span class="p">.</span><span class="w">
