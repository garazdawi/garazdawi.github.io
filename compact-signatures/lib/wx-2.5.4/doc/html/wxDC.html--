            <h1 class="signature" translate="no">setBrush(This :: <a href="#t:wxDC/0">wxDC</a>(), Brush :: <a href="wxBrush.html#t:wxBrush/0">wxBrush:wxBrush</a>())<span class="signature-arrow">&nbsp;-&gt;&nbsp;</span><span class="signature-result">ok</span></h1>




