\fB          decode_error | decrypt_error | export_restriction |\fR
\fB          protocol_version | insufficient_security | internal_error |\fR
\fB          inappropriate_fallback | user_canceled | no_renegotiation |\fR
\fB          unsupported_extension | certificate_unobtainable |\fR
