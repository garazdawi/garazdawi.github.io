    <a href="#filter/2" class="detail-link" data-no-tooltip="" aria-label="Link to this function">
      <i class="ri-link-m" aria-hidden="true"></i>
    </a>
    <div class="heading-with-actions">

      <div class="signature-row">


            <h1 class="signature" translate="no">filter(Pred :: fun((Element) -> <a href="../../../../lib/../erts/doc/html/erlang.html#t:boolean/0">boolean</a>()), Set1 :: <a href="#t:set/1">set</a>(Element))<span class="signature-arrow">&nbsp;-&gt;&nbsp;</span><span class="signature-result">Set2</span></h1>




          <a href="https://github.com/erlang/otp/blob/master/lib/stdlib/src/sets.erl#L868" class="icon-action" rel="help nofollow" aria-label="View Source">
