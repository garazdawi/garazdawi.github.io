            <pre translate="no">Module = <a href="../../../../lib/../erts/doc/html/erlang.html#t:module/0">module</a>()</pre>

            <pre translate="no">RecordName = <a href="../../../../lib/../erts/doc/html/erlang.html#t:atom/0">atom</a>()</pre>

            <pre translate="no">Result = {<a href="#t:create_options/0">create_options</a>(), [{FieldName :: <a href="../../../../lib/../erts/doc/html/erlang.html#t:atom/0">atom</a>(), Default :: <a href="../../../../lib/../erts/doc/html/erlang.html#t:dynamic/0">dynamic</a>()} | (FieldName :: <a href="../../../../lib/../erts/doc/html/erlang.html#t:atom/0">atom</a>())]}</pre>

