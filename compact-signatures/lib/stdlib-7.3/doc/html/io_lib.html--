<section class="detail" id="t:format_spec/0">


  <div class="detail-header">
    <a href="#t:format_spec/0" class="detail-link" data-no-tooltip="" aria-label="Link to this type">
      <i class="ri-link-m" aria-hidden="true"></i>
    </a>
    <div class="heading-with-actions">

      <div class="signature-row">

          <h1 class="signature" translate="no">format_spec()</h1>



          <a href="https://github.com/erlang/otp/blob/master/lib/stdlib/src/io_lib.erl#L158" class="icon-action" rel="help nofollow" aria-label="View Source">
            <i class="ri-code-s-slash-line" aria-hidden="true"></i>
          </a>

      </div>
    </div>
  </div>

  <section class="docstring">



        <div class="specs">

            <pre translate="no"><span class="attribute">-type</span> format_spec() ::
          #{control_char := <a href="../../../../lib/../erts/doc/html/erlang.html#t:char/0">char</a>(),
            args := [<a href="../../../../lib/../erts/doc/html/erlang.html#t:any/0">any</a>()],
            width := none | <a href="../../../../lib/../erts/doc/html/erlang.html#t:integer/0">integer</a>(),
            adjust := left | right,
            precision := none | <a href="../../../../lib/../erts/doc/html/erlang.html#t:integer/0">integer</a>(),
            pad_char := <a href="../../../../lib/../erts/doc/html/erlang.html#t:char/0">char</a>(),
            encoding := unicode | latin1,
            strings := <a href="../../../../lib/../erts/doc/html/erlang.html#t:boolean/0">boolean</a>(),
            maps_order => <a href="maps.html#t:iterator_order/0">maps:iterator_order</a>()}.</pre>

        </div>


<p>A map describing the contents of a format string.</p><ul><li><code class="inline">control_char</code> is the type of control sequence: <code class="inline">$P</code>, <code class="inline">$w</code>, and so on.</li><li><code class="inline">args</code> is a list of the arguments used by the control sequence, or an empty
list if the control sequence does not take any arguments.</li><li><code class="inline">width</code> is the field width.</li><li><code class="inline">adjust</code> is the adjustment.</li><li><code class="inline">precision</code> is the precision of the printed argument.</li><li><code class="inline">pad_char</code> is the padding character.</li><li><code class="inline">encoding</code> is set to <code class="inline">true</code> if translation modifier <code class="inline">t</code> is present.</li><li><code class="inline">strings</code> is set to <code class="inline">false</code> if modifier <code class="inline">l</code> is present.</li><li><code class="inline">maps_order</code> is set to <code class="inline">undefined</code> by default, <code class="inline">ordered</code> if modifier <code class="inline">k</code> is
present, or <code class="inline">reversed</code> or <code class="inline">CmpFun</code> if modifier <code class="inline">K</code> is present.</li></ul>
  </section>
</section>
