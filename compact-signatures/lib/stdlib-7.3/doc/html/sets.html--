</span><span class="gp unselectable">3&gt; </span><span class="n">S2</span><span class="w"> </span><span class="o">=</span><span class="w"> </span><span class="nc">sets</span><span class="p">:</span><span class="nf">from_list</span><span class="p" data-group-id="8560330638-5">(</span><span class="p" data-group-id="8560330638-6">[</span><span class="ss">q</span><span class="p">,</span><span class="ss">r</span><span class="p" data-group-id="8560330638-6">]</span><span class="p" data-group-id="8560330638-5">)</span><span class="p">.</span><span class="w">
</span><span class="gp unselectable">4&gt; </span><span class="n">Sets</span><span class="w"> </span><span class="o">=</span><span class="w"> </span><span class="p" data-group-id="8560330638-7">[</span><span class="n">S0</span><span class="p">,</span><span class="w"> </span><span class="n">S1</span><span class="p">,</span><span class="w"> </span><span class="n">S2</span><span class="p" data-group-id="8560330638-7">]</span><span class="p">.</span><span class="w">
</span><span class="gp unselectable">5&gt; </span><span class="nc">sets</span><span class="p">:</span><span class="nf">to_list</span><span class="p" data-group-id="8560330638-8">(</span><span class="nc">sets</span><span class="p">:</span><span class="nf">intersection</span><span class="p" data-group-id="8560330638-9">(</span><span class="p" data-group-id="8560330638-10">[</span><span class="n">S0</span><span class="p">,</span><span class="w"> </span><span class="n">S1</span><span class="p">,</span><span class="w"> </span><span class="n">S2</span><span class="p" data-group-id="8560330638-10">]</span><span class="p" data-group-id="8560330638-9">)</span><span class="p" data-group-id="8560330638-8">)</span><span class="p">.</span><span class="w">
</span><span class="p" data-group-id="8560330638-11">[</span><span class="p" data-group-id="8560330638-11">]</span><span class="w">
</span><span class="gp unselectable">6&gt; </span><span class="nc">sets</span><span class="p">:</span><span class="nf">to_list</span><span class="p" data-group-id="8560330638-12">(</span><span class="nc">sets</span><span class="p">:</span><span class="nf">intersection</span><span class="p" data-group-id="8560330638-13">(</span><span class="p" data-group-id="8560330638-14">[</span><span class="n">S0</span><span class="p">,</span><span class="w"> </span><span class="n">S1</span><span class="p" data-group-id="8560330638-14">]</span><span class="p" data-group-id="8560330638-13">)</span><span class="p" data-group-id="8560330638-12">)</span><span class="p">.</span><span class="w">
