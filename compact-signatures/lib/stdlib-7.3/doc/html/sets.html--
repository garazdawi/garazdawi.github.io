</span><span class="p" data-group-id="8678768285-7">[</span><span class="ss">a</span><span class="p">,</span><span class="ss">b</span><span class="p">,</span><span class="ss">c</span><span class="p" data-group-id="8678768285-7">]</span></code></pre>
