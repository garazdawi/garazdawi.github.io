<section class="detail" id="check/2">


    <span id="check/1"></span>

  <div class="detail-header">
    <a href="#check/2" class="detail-link" data-no-tooltip="" aria-label="Link to this function">
      <i class="ri-link-m" aria-hidden="true"></i>
    </a>
    <div class="heading-with-actions">

        <div class="signature-row">
          <h1 class="signature" translate="no">check(FileName)<span class="signature-arrow">&nbsp;≡&nbsp;</span><span class="signature-result">check([FileName], [])</span></h1>


            <a href="https://github.com/erlang/otp/blob/master/lib/stdlib/src/file_sorter.erl#L407" class="icon-action" rel="help nofollow" aria-label="View Source">
              <i class="ri-code-s-slash-line" aria-hidden="true"></i>
            </a>

        </div>

      <div class="signature-row">


            <h1 class="signature" translate="no">check(FileNames :: <a href="#t:file_names/0">file_names</a>(), Options :: <a href="#t:options/0">options</a>())<span class="signature-arrow">&nbsp;-&gt;&nbsp;</span><span class="signature-result">Reply</span></h1>




          <a href="https://github.com/erlang/otp/blob/master/lib/stdlib/src/file_sorter.erl#L421" class="icon-action" rel="help nofollow" aria-label="View Source">
            <i class="ri-code-s-slash-line" aria-hidden="true"></i>
          </a>

      </div>
    </div>
  </div>

  <section class="docstring">


        <div class="specs">
          <h4 class="specs-title">Types</h4>

            <pre translate="no">Reply = {ok, [Result]} | {error, <a href="#t:reason/0">reason</a>()}</pre>

            <pre translate="no">Result = {FileName, TermPosition, <a href="../../../../lib/../erts/doc/html/erlang.html#t:term/0">term</a>()}</pre>

            <pre translate="no">FileName = <a href="#t:file_name/0">file_name</a>()</pre>

            <pre translate="no">TermPosition = <a href="../../../../lib/../erts/doc/html/erlang.html#t:pos_integer/0">pos_integer</a>()</pre>

        </div>


<p>Checks files for sortedness. If a file is not sorted, the first out-of-order
element is returned. The first term on a file has position 1.</p>
  </section>
</section>
