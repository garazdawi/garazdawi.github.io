<section class="detail" id="append/2">


  <div class="detail-header">
    <a href="#append/2" class="detail-link" data-no-tooltip="" aria-label="Link to this function">
      <i class="ri-link-m" aria-hidden="true"></i>
    </a>
    <div class="heading-with-actions">

      <div class="signature-row">


            <h1 class="signature" translate="no">append(Value :: <a href="../../../../lib/../erts/doc/html/erlang.html#t:any/0">any</a>(), Array :: <a href="#t:array/1">array</a>(Type))<span class="signature-arrow">&nbsp;-&gt;&nbsp;</span><span class="signature-result"><a href="#t:array/1">array</a>(Type)</span></h1>



