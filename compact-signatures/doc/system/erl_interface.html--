        </span><span class="k">if</span><span class="w"> </span><span class="p" data-group-id="4326174751-20">(</span><span class="nf">ei_decode_tuple_header</span><span class="p" data-group-id="4326174751-21">(</span><span class="n">buf</span><span class="p">,</span><span class="w"> </span><span class="o">&amp;</span><span class="n">index</span><span class="p">,</span><span class="w"> </span><span class="o">&amp;</span><span class="n">arity</span><span class="p" data-group-id="4326174751-21">)</span><span class="w"> </span><span class="o">!=</span><span class="w"> </span><span class="mi">0</span><span class="p" data-group-id="4326174751-20">)</span><span class="w">
