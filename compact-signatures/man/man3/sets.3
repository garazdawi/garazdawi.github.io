.PP
\fBNOTE: \fRWhile the three set implementations offer the same \fIfunctionality\fR with respect to the aforementioned functions, their overall \fIbehavior\fR may differ. As mentioned, this module considers elements as different if and only if they do not match (\fI=:=\fR), while both \fIordsets\fR and \fIgb_sets\fR consider elements as different if and only if they do not compare equal (\fI==\fR).

.PP
\fBExamples\fR

.IP
.nf
1> sets:is_element(1.0, sets:from_list([1])).
false
2> ordsets:is_element(1.0, ordsets:from_list([1])).
true
3> gb_sets:is_element(1.0, gb_sets:from_list([1])).
true

.fi


.PP
\fBSee Also\fR

.PP
\fIgb_sets\fR, \fIordsets\fR

.SH DATA TYPES
.LP
.B
\fBset() :: set(_).\fR

.br
.RS

.RE
.B
\fB-opaque set(Element) \fR

.br
.RS
.PP
As returned by \fInew/0\fR.


.RE
.SH FUNCTIONS
.LP
.B
\fBadd_element(Element, Set1) -> Set2\fR
\fB                     when Set1 :: set(Element), Set2 :: set(Element).\fR

.br
.RS
.PP
Returns a new set formed from \fISet1\fR with \fIElement\fR inserted.

.SS "Examples"

.IP
.nf
1> S0 = sets:new().
2> S1 = sets:add_element(7, S0).
3> sets:to_list(S1).
[7]
4> S2 = sets:add_element(42, S1).
5> lists:sort(sets:to_list(S2)).
[7,42]
6> S2 = sets:add_element(42, S1).
7> lists:sort(sets:to_list(S2)).
[7,42]

.fi


.RE
.B
\fBdel_element(Element, Set1) -> Set2\fR
\fB                     when Set1 :: set(Element), Set2 :: set(Element).\fR

.br
.RS
.PP
Returns a copy of \fISet1\fR with \fIElement\fR removed.

.SS "Examples"

.IP
.nf
1> S = sets:from_list([a,b]).
2> sets:to_list(sets:del_element(b, S)).
[a]
3> S = sets:del_element(x, S).
4> lists:sort(sets:to_list(S)).
[a,b]

.fi


.RE
.B
\fBfilter(Pred, Set1) -> Set2\fR
\fB                when\fR
\fB                    Pred :: fun((Element) -> boolean()),\fR
\fB                    Set1 :: set(Element),\fR
\fB                    Set2 :: set(Element).\fR

.br
.RS
.PP
Filters elements in \fISet1\fR using predicate function \fIPred\fR.

.SS "Examples"

.IP
.nf
1> S = sets:from_list([1,2,3,4,5,6,7]).
2> IsEven = fun(N) -> N rem 2 =:= 0 end.
3> Filtered = sets:filter(IsEven, S).
4> lists:sort(sets:to_list(Filtered)).
[2,4,6]

.fi


.RE
.B
\fBfiltermap(Fun, Set1) -> Set2\fR
\fB                   when\fR
\fB                       Fun ::\fR
\fB                           fun((Element1) ->\fR
\fB                                   boolean() | {true, Element2}),\fR
\fB                       Set1 :: set(Element1),\fR
\fB                       Set2 :: set(Element1 | Element2).\fR

.br
.RS
.PP
Calls \fIFun(Elem)\fR for each \fIElem\fR of \fISet1\fR to update or remove elements from \fISet1\fR.

.PP
\fIFun/1\fR must return either a Boolean or a tuple \fI{true, Value}\fR. The function returns the set of elements for which \fIFun\fR returns a new value, with \fItrue\fR being equivalent to \fI{true, Elem}\fR.

.PP
\fIsets:filtermap/2\fR behaves as if it were defined as follows:

.IP
.nf
filtermap(Fun, Set1) ->
    sets:from_list(lists:filtermap(Fun, sets:to_list(Set1))).

.fi

.SS "Examples"

.IP
.nf
1> S = sets:from_list([2,4,5,6,8,9]).
2> F = fun(X) ->
           case X rem 2 of
               0 -> {true, X div 2};
               1 -> false
           end
        end.
3> Set = sets:filtermap(F, S).
4> lists:sort(sets:to_list(Set)).
[1,2,3,4]

.fi


.RE
.B
\fBfold(Function, Acc0, Set) -> Acc1\fR
\fB              when\fR
\fB                  Function :: fun((Element, AccIn) -> AccOut),\fR
\fB                  Set :: set(Element),\fR
\fB                  Acc0 :: Acc,\fR
\fB                  Acc1 :: Acc,\fR
\fB                  AccIn :: Acc,\fR
\fB                  AccOut :: Acc.\fR

.br
.RS
.PP
Folds \fIFunction\fR over every element in \fISet\fR and returns the final value of the accumulator.

.PP
The evaluation order is undefined.

.SS "Examples"

.IP
.nf
1> S = sets:from_list([1,2,3,4]).
2> Plus = fun erlang:'+'/2.
3> sets:fold(Plus, 0, S).
10

.fi


.RE
.B
\fBfrom_list(List) -> Set when List :: [Element], Set :: set(Element).\fR

.br
.RS
.PP
Returns a set of the elements in \fIList\fR.

.SS "Examples"

.IP
.nf
1> S = sets:from_list([a,b,c]).
2> lists:sort(sets:to_list(S)).
[a,b,c]

.fi


.RE
.B
\fBfrom_list(List, [{version, 1..2}]) -> Set\fR
\fB                   when List :: [Element], Set :: set(Element).\fR

.br
.RS
.PP
Returns a set of the elements in \fIList\fR of the given version.

.SS "Examples"

.IP
.nf
1> S = sets:from_list([a,b,c], [{version, 1}]).
2> lists:sort(sets:to_list(S)).
[a,b,c]

.fi


.RE
.B
\fBintersection(SetList) -> Set\fR
\fB                      when\fR
\fB                          SetList :: [set(Element), ...],\fR
\fB                          Set :: set(Element).\fR

.br
.RS
.PP
Returns the intersection of the non-empty list of sets.

.PP
The intersection of multiple sets is a new set that contains only the elements that are present in all sets.

.SS "Examples"

.IP
.nf
1> S0 = sets:from_list([a,b,c,d]).
2> S1 = sets:from_list([d,e,f]).
3> S2 = sets:from_list([q,r]).
4> Sets = [S0, S1, S2].
5> sets:to_list(sets:intersection([S0, S1, S2])).
[]
6> sets:to_list(sets:intersection([S0, S1])).
[d]
7> sets:intersection([]).
** exception error: no function clause matching sets:intersection([])

.fi


.RE
.B
\fBintersection(Set1, Set2) -> Set3\fR
\fB                      when\fR
\fB                          Set1 :: set(Element),\fR
\fB                          Set2 :: set(Element),\fR
\fB                          Set3 :: set(Element).\fR

.br
.RS
.PP
Returns the intersection of \fISet1\fR and \fISet2\fR.

.PP
The intersection of two sets is a new set that contains only the elements that are present in both sets.

.SS "Examples"

.IP
.nf
1> S0 = sets:from_list([a,b,c,d]).
2> S1 = sets:from_list([c,d,e,f]).
3> S2 = sets:from_list([q,r]).
4> Intersection = sets:intersection(S0, S1).
5> lists:sort(sets:to_list(Intersection)).
[c,d]
6> sets:to_list(sets:intersection(S1, S2)).
[]

.fi


.RE
.B
\fBis_disjoint(Set1, Set2) -> boolean()\fR
\fB                     when Set1 :: set(Element), Set2 :: set(Element).\fR

.br
.RS
.PP
Returns \fItrue\fR if \fISet1\fR and \fISet2\fR are disjoint; otherwise, returns \fIfalse\fR.

.PP
Two sets are disjoint if they have no elements in common.

.PP
This function is equivalent to \fIsets:is_empty(sets:intersection(Set1, Set2))\fR, but faster.

.SS "Examples"

.IP
.nf
1> S0 = sets:from_list([a,b,c,d]).
2> S1 = sets:from_list([d,e,f]).
3> S2 = sets:from_list([q,r]).
4> sets:is_disjoint(S0, S1).
false
5> sets:is_disjoint(S1, S2).
true

.fi


.RE
.B
\fBis_element(Element, Set) -> boolean() when Set :: set(Element).\fR

.br
.RS
.PP
Returns \fItrue\fR if \fIElement\fR is an element of \fISet\fR; otherwise, returns \fIfalse\fR.

.SS "Examples"

.IP
.nf
1> S = sets:from_list([a,b,c]).
2> sets:is_element(42, S).
false
3> sets:is_element(b, S).
true

.fi


.RE
.B
\fBis_empty(Set) -> boolean() when Set :: set().\fR

.br
.RS
.PP
Returns \fItrue\fR if \fISet\fR is an empty set; otherwise, returns \fIfalse\fR.

.SS "Examples"

.IP
.nf
1> sets:is_empty(sets:new()).
true
2> sets:is_empty(sets:from_list([1])).
false

.fi


.RE
.B
\fBis_equal(Set1, Set2) -> boolean()\fR
\fB                  when Set1 :: set(), Set2 :: set().\fR

.br
.RS
.PP
Returns \fItrue\fR if \fISet1\fR and \fISet2\fR are equal, that is, if every element of one set is also a member of the other set; otherwise, returns \fIfalse\fR.

.SS "Examples"

.IP
.nf
1> Empty = sets:new().
2> S = sets:from_list([a,b]).
3> sets:is_equal(S, S).
true
4> sets:is_equal(S, Empty).
false
5> OldSet = sets:from_list([a,b], [{version,1}]).
6> sets:is_equal(S, OldSet).
true
7> S =:= OldSet.
false

.fi


.RE
.B
\fBis_set(Set) -> boolean() when Set :: term().\fR

.br
.RS
.PP
Returns \fItrue\fR if \fISet\fR appears to be a set of elements; otherwise, returns \fIfalse\fR.

.PP
\fBNOTE: \fRNote that the test is shallow and will return \fItrue\fR for any term that coincides with the possible representations of a set. See also note on data types. Furthermore, since sets are opaque, calling this function on terms that are not sets could result in \fIdialyzer\fR warnings.


.SS "Examples"

.IP
.nf
1> sets:is_set(sets:new()).
true
2> sets:is_set(sets:new([{version,1}])).
true
3> sets:is_set(0).
false

.fi


.RE
.B
\fBis_subset(Set1, Set2) -> boolean()\fR
\fB                   when Set1 :: set(Element), Set2 :: set(Element).\fR

.br
.RS
.PP
Returns \fItrue\fR when every element of \fISet1\fR is also a member of \fISet2\fR; otherwise, returns \fIfalse\fR.

.SS "Examples"

.IP
.nf
1> S0 = sets:from_list([a,b,c,d]).
2> S1 = sets:from_list([c,d]).
3> sets:is_subset(S1, S0).
true
4> sets:is_subset(S0, S1).
false
5> sets:is_subset(S0, S0).
true

.fi


.RE
.B
\fBmap(Fun, Set1) -> Set2\fR
\fB             when\fR
\fB                 Fun :: fun((Element1) -> Element2),\fR
\fB                 Set1 :: set(Element1),\fR
\fB                 Set2 :: set(Element2).\fR

.br
.RS
.PP
Maps elements in \fISet1\fR with mapping function \fIFun\fR.

.SS "Examples"

.IP
.nf
1> S = sets:from_list([1,2,3,4,5,6,7]).
2> F = fun(N) -> N div 2 end.
3> Mapped = sets:map(F, S).
4> lists:sort(sets:to_list(Mapped)).
[0,1,2,3]

.fi


.RE
.B
\fBnew() -> set(none()).\fR

.br
.RS
.PP
Returns a new empty set.

.SS "Examples"

.IP
.nf
1> sets:to_list(sets:new()).
[]

.fi


.RE
.B
\fBnew([{version, 1..2}]) -> set(none()).\fR

.br
.RS
.PP
Returns a new empty set of the given version.

.SS "Examples"

.IP
.nf
1> sets:to_list(sets:new([{version, 1}])).
[]
2> sets:new() =:= sets:new([{version, 2}]).
true

.fi


.RE
.B
\fBsize(Set) -> non_neg_integer() when Set :: set().\fR

.br
.RS
.PP
Returns the number of elements in \fISet\fR.

.SS "Examples"

.IP
.nf
1> sets:size(sets:new()).
0
2> sets:size(sets:from_list([4,5,6])).
3

.fi


.RE
.B
\fBsubtract(Set1, Set2) -> Set3\fR
\fB                  when\fR
\fB                      Set1 :: set(Element),\fR
\fB                      Set2 :: set(Element),\fR
\fB                      Set3 :: set(Element).\fR

.br
.RS
.PP
Returns a new set containing the elements of \fISet1\fR that are not elements in \fISet2\fR.

.SS "Examples"

.IP
.nf
1> S0 = sets:from_list([a,b,c,d]).
2> S1 = sets:from_list([c,d,e,f]).
3> lists:sort(sets:to_list(sets:subtract(S0, S1))).
[a,b]
4> lists:sort(sets:to_list(sets:subtract(S1, S0))).
[e,f]

.fi


.RE
.B
\fBto_list(Set) -> List when Set :: set(Element), List :: [Element].\fR

.br
.RS
.PP
Returns the elements of \fISet\fR as a list.

.PP
The order of the returned elements is undefined.

.SS "Examples"

.IP
.nf
1> S = sets:from_list([1,2,3]).
2> lists:sort(sets:to_list(S)).
[1,2,3]

.fi


.RE
.B
\fBunion(SetList) -> Set\fR
\fB               when SetList :: [set(Element)], Set :: set(Element).\fR

.br
.RS
.PP
Returns the union of a list of sets.

.PP
The union of multiple sets is a new set that contains all the elements from all sets, without duplicates.

.SS "Examples"

.IP
.nf
1> S0 = sets:from_list([a,b,c,d]).
2> S1 = sets:from_list([d,e,f]).
3> S2 = sets:from_list([q,r]).
4> Sets = [S0, S1, S2].
5> Union = sets:union(Sets).
6> lists:sort(sets:to_list(Union)).
[a,b,c,d,e,f,q,r]

.fi


.RE
.B
\fBunion(Set1, Set2) -> Set3\fR
\fB               when\fR
\fB                   Set1 :: set(Element),\fR
\fB                   Set2 :: set(Element),\fR
\fB                   Set3 :: set(Element).\fR

.br
.RS
.PP
Returns the union of \fISet1\fR and \fISet2\fR.

.PP
The union of two sets is a new set that contains all the elements from both sets, without duplicates.

.SS "Examples"

.IP
.nf
1> S0 = sets:from_list([a,b,c,d]).
2> S1 = sets:from_list([c,d,e,f]).
3> Union = sets:union(S0, S1).
4> lists:sort(sets:to_list(Union)).
[a,b,c,d,e,f]

.fi


.RE
