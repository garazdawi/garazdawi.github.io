</span><span class="gp unselectable">5&gt; </span><span class="nc">lists</span><span class="p">:</span><span class="nf">sort</span><span class="p" data-group-id="4895589493-6">(</span><span class="nc">sets</span><span class="p">:</span><span class="nf">to_list</span><span class="p" data-group-id="4895589493-7">(</span><span class="n">S2</span><span class="p" data-group-id="4895589493-7">)</span><span class="p" data-group-id="4895589493-6">)</span><span class="p">.</span><span class="w">
</span><span class="p" data-group-id="4895589493-8">[</span><span class="mi">7</span><span class="p">,</span><span class="mi">42</span><span class="p" data-group-id="4895589493-8">]</span><span class="w">
</span><span class="gp unselectable">6&gt; </span><span class="n">S2</span><span class="w"> </span><span class="o">=</span><span class="w"> </span><span class="nc">sets</span><span class="p">:</span><span class="nf">add_element</span><span class="p" data-group-id="4895589493-9">(</span><span class="mi">42</span><span class="p">,</span><span class="w"> </span><span class="n">S1</span><span class="p" data-group-id="4895589493-9">)</span><span class="p">.</span><span class="w">
</span><span class="gp unselectable">7&gt; </span><span class="nc">lists</span><span class="p">:</span><span class="nf">sort</span><span class="p" data-group-id="4895589493-10">(</span><span class="nc">sets</span><span class="p">:</span><span class="nf">to_list</span><span class="p" data-group-id="4895589493-11">(</span><span class="n">S2</span><span class="p" data-group-id="4895589493-11">)</span><span class="p" data-group-id="4895589493-10">)</span><span class="p">.</span><span class="w">
</span><span class="p" data-group-id="4895589493-12">[</span><span class="mi">7</span><span class="p">,</span><span class="mi">42</span><span class="p" data-group-id="4895589493-12">]</span></code></pre>
