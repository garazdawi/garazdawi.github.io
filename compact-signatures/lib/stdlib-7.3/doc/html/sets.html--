    <div class="summary-row">
      <div class="summary-signature">
        <a href="#to_list/1" data-no-tooltip="" translate="no">to_list(Set)</a>

      </div>

        <div class="summary-synopsis"><p>Returns the elements of <code class="inline">Set</code> as a list.</p></div>

