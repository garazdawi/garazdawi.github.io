            <h1 class="signature" translate="no">keys(Tree :: <a href="#t:tree/2">tree</a>(Key, Value :: <a href="../../../../lib/../erts/doc/html/erlang.html#t:term/0">term</a>()))<span class="signature-arrow">&nbsp;-&gt;&nbsp;</span><span class="signature-result">[Key]</span></h1>




