<section class="detail" id="iterator/1">


  <div class="detail-header">
    <a href="#iterator/1" class="detail-link" data-no-tooltip="" aria-label="Link to this function">
      <i class="ri-link-m" aria-hidden="true"></i>
    </a>
    <div class="heading-with-actions">

      <div class="signature-row">


            <h1 class="signature" translate="no">iterator(Tree :: <a href="#t:tree/2">tree</a>(Key, Value))<span class="signature-arrow">&nbsp;-&gt;&nbsp;</span><span class="signature-result">Iter</span></h1>




          <a href="https://github.com/erlang/otp/blob/master/lib/stdlib/src/gb_trees.erl#L955" class="icon-action" rel="help nofollow" aria-label="View Source">
            <i class="ri-code-s-slash-line" aria-hidden="true"></i>
