      <div class="signature-row">


            <h1 class="signature" translate="no">stop(Process :: <a href="../../../../lib/../erts/doc/html/erlang.html#t:pid/0">pid</a>() | RegName | {RegName, <a href="../../../../lib/../erts/doc/html/erlang.html#t:node/0">node</a>()})<span class="signature-arrow">&nbsp;-&gt;&nbsp;</span><span class="signature-result">ok</span></h1>



          <span class="note">(since OTP 18.0)</span>


          <a href="https://github.com/erlang/otp/blob/master/lib/stdlib/src/proc_lib.erl#L1559" class="icon-action" rel="help nofollow" aria-label="View Source">
