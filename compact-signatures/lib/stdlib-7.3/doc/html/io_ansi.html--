            <h1 class="signature" translate="no">reverse_index()<span class="signature-arrow">&nbsp;-&gt;&nbsp;</span><span class="signature-result"><a href="unicode.html#t:chardata/0">unicode:chardata</a>()</span></h1>



          <span class="note">(since OTP @OTP-20028@)</span>


          <a href="https://github.com/erlang/otp/blob/master/lib/stdlib/src/io_ansi.erl#L1700" class="icon-action" rel="help nofollow" aria-label="View Source">
