.TH gb_trees 3 "stdlib 7.3" "Ericsson AB" "Erlang Module Definition"
.SH NAME
gb_trees \- General balanced trees.

.SH DESCRIPTION
.PP
This module provides Prof. Arne Andersson's General Balanced Trees. These have no storage overhead compared to unbalanced binary trees, and their performance is better than AVL trees.

.PP
This module considers two keys as different if and only if they do not compare equal (\fI==\fR).

.SS "Data Structure"

.PP
Trees and iterators are built using opaque data structures that should not be pattern-matched from outside this module.

.PP
There is no attempt to balance trees after deletions. As deletions do not increase the height of a tree, this should be OK.

.PP
The original balance condition \fIh(T) <= ceil(c * log(|T|))\fR has been changed to the similar (but not quite equivalent) condition \fI2 ^ h(T) <= |T| ^ c\fR. This should also be OK.

.PP
\fBSee Also\fR

.PP
\fIdict\fR, \fIgb_sets\fR, \fImaps\fR

.SH DATA TYPES
.LP
.B
\fBiter() :: iter(_, _).\fR

.br
.RS

.RE
.B
\fB-opaque iter(Key, Value) \fR

.br
.RS
.PP
A general balanced tree iterator.


.RE
.B
\fBtree() :: tree(_, _).\fR

.br
.RS

.RE
.B
\fB-opaque tree(Key, Value) \fR

.br
.RS
.PP
A general balanced tree.


.RE
.SH FUNCTIONS
.LP
.B
\fBbalance(Tree1) -> Tree2\fR
\fB                 when\fR
\fB                     Tree1 :: tree(Key, Value),\fR
\fB                     Tree2 :: tree(Key, Value).\fR

.br
.RS
.PP
Rebalances \fITree1\fR.

.PP
Note that this is rarely necessary, but can be motivated when many nodes have been deleted from the tree without further insertions. Rebalancing can then be forced to minimize lookup times, as deletion does not rebalance the tree.

.SS "Examples"

.IP
.nf
1> Tree1 = gb_trees:from_orddict([{I,2*I} || I <- lists:seq(1, 100)]).
2> Delete = fun gb_trees:delete/2.
3> Tree2 = lists:foldl(Delete, Tree1, lists:seq(1, 50)).
4> gb_sets:size(Tree2).
50
5> Tree3 = gb_trees:balance(Tree2).

.fi


.RE
.B
\fBdelete(Key, Tree1) -> Tree2\fR
\fB                when\fR
\fB                    Tree1 :: tree(Key, Value), Tree2 :: tree(Key, Value).\fR

.br
.RS
.PP
Removes the node with key \fIKey\fR from \fITree1\fR, returning the new tree; raises an exception if \fIKey\fR is not present.

.SS "Examples"

.IP
.nf
1> Tree1 = gb_trees:from_orddict([{a,1},{b,2}]).
2> Tree2 = gb_trees:delete(a, Tree1).
3> gb_trees:to_list(Tree2).
[{b,2}]

.fi


.RE
.B
\fBdelete_any(Key, Tree1) -> Tree2\fR
\fB                    when\fR
\fB                        Tree1 :: tree(Key, Value),\fR
\fB                        Tree2 :: tree(Key, Value).\fR

.br
.RS
.PP
Removes the node with key \fIKey\fR from \fITree1\fR if present and returns the resulting tree; otherwise, returns \fITree1\fR unchanged.

.SS "Examples"

.IP
.nf
1> Tree1 = gb_trees:from_orddict([{a,1},{b,2}]).
2> Tree2 = gb_trees:delete_any(a, Tree1).
3> gb_trees:to_list(Tree2).
[{b,2}]
4> Tree3 = gb_trees:delete_any(z, Tree2).
5> Tree2 == Tree3.
true

.fi


.RE
.B
\fBempty() -> tree(none(), none()).\fR

.br
.RS
.PP
Returns a new empty tree.

.SS "Examples"

.IP
.nf
1> gb_trees:to_list(gb_trees:empty()).
[]

.fi


.RE
.B
\fBenter(Key, Value, Tree1) -> Tree2\fR
\fB               when Tree1 :: tree(Key, Value), Tree2 :: tree(Key, Value).\fR

.br
.RS
.PP
Inserts \fIKey\fR with value \fIValue\fR into \fITree1\fR if not present, or updates the value for \fIKey\fR to \fIValue\fR if present; returns the new tree.

.SS "Examples"

.IP
.nf
1> Tree1 = gb_trees:from_orddict([{a,1},{b,2}]).
2> Tree2 = gb_trees:enter(c, 10, Tree1).
3> Tree3 = gb_trees:enter(a, 100, Tree2).
4> gb_trees:to_list(Tree3).
[{a,100},{b,2},{c,10}]

.fi


.RE
.B
\fBfrom_orddict(List) -> Tree\fR
\fB                      when\fR
\fB                          List :: [{Key, Value}],\fR
\fB                          Tree :: tree(Key, Value).\fR

.br
.RS
.PP
Turns an ordered list \fIList\fR of key-value tuples into a tree.

.PP
The list must not contain duplicate keys.

.SS "Examples"

.IP
.nf
1> Tree = gb_trees:from_orddict([{a,1},{b,2}]).
2> gb_trees:to_list(Tree).
[{a,1},{b,2}]

.fi


.RE
.B
\fBget(Key, Tree) -> Value when Tree :: tree(Key, Value).\fR

.br
.RS
.PP
Retrieves the value stored with \fIKey\fR in \fITree\fR; raises an exception if \fIKey\fR is not present.

.SS "Examples"

.IP
.nf
1> Tree = gb_trees:from_orddict([{a,1},{b,2}]).
2> gb_trees:get(b, Tree).
2

.fi


.RE
.B
\fBinsert(Key, Value, Tree1) -> Tree2\fR
\fB                when\fR
\fB                    Tree1 :: tree(Key, Value), Tree2 :: tree(Key, Value).\fR

.br
.RS
.PP
Inserts \fIKey\fR with value \fIValue\fR into \fITree1\fR, returning the new tree; raises an exception if \fIKey\fR is already present.

.SS "Examples"

.IP
.nf
1> Tree1 = gb_trees:from_orddict([{a,1},{b,2}]).
2> Tree2 = gb_trees:insert(c, 10, Tree1).
3> gb_trees:to_list(Tree2).
[{a,1},{b,2},{c,10}]

.fi


.RE
.B
\fBis_defined(Key, Tree) -> boolean()\fR
\fB                    when Tree :: tree(Key, Value :: term()).\fR

.br
.RS
.PP
Returns \fItrue\fR if \fIKey\fR is present in \fITree\fR; otherwise, returns \fIfalse\fR.

.SS "Examples"

.IP
.nf
1> Tree = gb_trees:from_orddict([{a,1},{b,2},{c,3}]).
2> gb_trees:is_defined(a, Tree).
true
3> gb_trees:is_defined(x, Tree).
false

.fi


.RE
.B
\fBis_empty(Tree) -> boolean() when Tree :: tree().\fR

.br
.RS
.PP
Returns \fItrue\fR if \fITree\fR is an empty tree; otherwise, returns \fIfalse\fR.

.SS "Examples"

.IP
.nf
1> gb_trees:is_empty(gb_trees:empty()).
true
2> gb_trees:is_empty(gb_trees:from_orddict([{a,99}])).
false

.fi


.RE
.B
\fBiterator(Tree) -> Iter\fR
\fB                  when\fR
\fB                      Tree :: tree(Key, Value), Iter :: iter(Key, Value).\fR

.br
.RS
.PP
Returns an iterator that can be used for traversing the entries of \fITree\fR; see \fInext/1\fR.

.PP
Equivalent to \fIiterator(Tree, ordered)\fR.

.SS "Examples"

.IP
.nf
1> Tree = gb_trees:from_orddict([{a,1},{b,2},{c,3}]).
2> Iter0 = gb_trees:iterator(Tree).
3> {a,1,Iter1} = gb_trees:next(Iter0).

.fi


.RE
.B
\fBiterator(Tree, Order) -> Iter\fR
\fB                  when\fR
\fB                      Tree :: tree(Key, Value),\fR
\fB                      Iter :: iter(Key, Value),\fR
\fB                      Order :: ordered | reversed.\fR

.br
.RS
.PP
Returns an iterator that can be used for traversing the entries of \fITree\fR in either \fIordered\fR or \fIreversed\fR direction; see \fInext/1\fR.

.PP
The implementation of this is very efficient; traversing the whole tree using \fInext/1\fR is only slightly slower than getting the list of all elements using \fIto_list/1\fR and traversing that. The main advantage of the iterator approach is that it does not require the complete list of all elements to be built in memory at one time.

.SS "Examples"

.IP
.nf
1> Tree = gb_trees:from_orddict([{a,1},{b,2},{c,3}]).
2> Iter0 = gb_trees:iterator(Tree, ordered).
3> {a,1,Iter1} = gb_trees:next(Iter0).
4> RevIter0 = gb_trees:iterator(Tree, reversed).
5> {c,3,RevIter1} = gb_trees:next(RevIter0).

.fi


.RE
.B
\fBiterator_from(Key, Tree) -> Iter\fR
\fB                       when\fR
\fB                           Tree :: tree(Key, Value),\fR
\fB                           Iter :: iter(Key, Value).\fR

.br
.RS
.PP
Returns an iterator that can be used for traversing the entries of \fITree\fR starting from \fIKey\fR; see \fInext/1\fR.

.PP
The difference as compared to the iterator returned by \fIiterator/1\fR is that the iterator starts with the first key greater than or equal to \fIKey\fR.

.PP
Equivalent to \fIiterator_from(Key, Tree, ordered)\fR.

.SS "Examples"

.IP
.nf
1> Tree = gb_trees:from_orddict([{a,1},{b,2},{c,3},{d,4}]).
2> Iter0 = gb_trees:iterator_from(aa, Tree).
3> {b,2,Iter1} = gb_trees:next(Iter0).
4> {c,3,Iter2} = gb_trees:next(Iter1).

.fi


.RE
.B
\fBiterator_from(Key, Tree, Order) -> Iter\fR
\fB                       when\fR
\fB                           Tree :: tree(Key, Value),\fR
\fB                           Iter :: iter(Key, Value),\fR
\fB                           Order :: ordered | reversed.\fR

.br
.RS
.PP
Returns an iterator that can be used for traversing the entries of \fITree\fR in either \fIordered\fR or \fIreversed\fR direction starting from \fIKey\fR; see \fInext/1\fR.

.PP
The difference as compared to the iterator returned by \fIiterator/2\fR is that the iterator starts with the first key next to or equal to \fIKey\fR.

.SS "Examples"

.IP
.nf
1> Tree = gb_trees:from_orddict([{a,1},{b,2},{c,3},{d,4}]).
2> Iter0 = gb_trees:iterator_from(aa, Tree, ordered).
3> {b,2,Iter1} = gb_trees:next(Iter0).
4> RevIter0 = gb_trees:iterator_from(c, Tree, reversed).
5> {c,3,RevIter1} = gb_trees:next(RevIter0).
6> {b,2,RevIter2} = gb_trees:next(RevIter1).

.fi


.RE
.B
\fBkeys(Tree) -> [Key] when Tree :: tree(Key, Value :: term()).\fR

.br
.RS
.PP
Returns the keys in \fITree\fR as an ordered list.

.SS "Examples"

.IP
.nf
1> Tree = gb_trees:from_orddict([{a,1},{b,2},{c,3}]).
2> gb_trees:keys(Tree).
[a,b,c]
3> gb_trees:keys(gb_trees:empty()).
[]

.fi


.RE
.B
\fBlarger(Key1, Tree) -> none | {Key2, Value}\fR
\fB                when Key1 :: Key, Key2 :: Key, Tree :: tree(Key, Value).\fR

.br
.RS
.PP
Returns \fI{Key2, Value}\fR, where \fIKey2\fR is the least key strictly greater than \fIKey1\fR, \fIValue\fR is the value associated with this key.

.PP
Returns \fInone\fR if no such pair exists.

.SS "Examples"

.IP
.nf
1> Tree = gb_trees:from_orddict([{a,1},{b,2},{c,3}]).
2> gb_trees:larger(c, Tree).
none
3> gb_trees:larger(bb, Tree).
{c,3}
4> gb_trees:larger(a, Tree).
{b,2}

.fi


.RE
.B
\fBlargest(Tree) -> {Key, Value} when Tree :: tree(Key, Value).\fR

.br
.RS
.PP
Returns \fI{Key, Value}\fR, where \fIKey\fR is the largest key in \fITree\fR, and \fIValue\fR is the value associated with this key.

.PP
Assumes that the tree is not empty.

.SS "Examples"

.IP
.nf
1> Tree = gb_trees:from_orddict([{a,1},{b,2},{c,3}]).
2> gb_trees:largest(Tree).
{c,3}

.fi


.RE
.B
\fBlookup(Key, Tree) -> none | {value, Value}\fR
\fB                when Tree :: tree(Key, Value).\fR

.br
.RS
.PP
Looks up \fIKey\fR in \fITree\fR and returns \fI{value, Value}\fR if found, or \fInone\fR if not present.

.SS "Examples"

.IP
.nf
1> Tree = gb_trees:from_orddict([{a,1},{b,2},{c,3}]).
2> gb_trees:lookup(a, Tree).
{value,1}
3> gb_trees:lookup(z, Tree).
none

.fi


.RE
.B
\fBmap(Function, Tree1) -> Tree2\fR
\fB             when\fR
\fB                 Function ::\fR
\fB                     fun((K :: Key, V1 :: Value1) -> V2 :: Value2),\fR
\fB                 Tree1 :: tree(Key, Value1),\fR
\fB                 Tree2 :: tree(Key, Value2).\fR

.br
.RS
.PP
Maps function F(K, V1) -> V2 to all key-value pairs of tree \fITree1\fR, returning a new tree \fITree2\fR with the same set of keys as \fITree1\fR and the new set of values \fIV2\fR.

.SS "Examples"

.IP
.nf
1> Tree0 = gb_trees:from_orddict([{a,1},{b,2},{c,3}]).
2> Tree1 = gb_trees:map(fun(_, V) -> 2 * V end, Tree0).
3> gb_trees:to_list(Tree1).
[{a,2},{b,4},{c,6}]

.fi


.RE
.B
\fBnext(Iter1) -> none | {Key, Value, Iter2}\fR
\fB              when Iter1 :: iter(Key, Value), Iter2 :: iter(Key, Value).\fR

.br
.RS
.PP
Returns \fI{Key, Value, Iter2}\fR, where \fIKey\fR is the next key referred to by iterator \fIIter1\fR, and \fIIter2\fR is the new iterator to be used for traversing the remaining nodes, or the atom \fInone\fR if no nodes remain.

.SS "Examples"

.IP
.nf
1> Tree = gb_trees:from_orddict([{a,1},{b,2},{c,3}]).
2> Iter0 = gb_trees:iterator(Tree).
3> {a,1,Iter1} = gb_trees:next(Iter0).
4> {b,2,Iter2} = gb_trees:next(Iter1).
5> {c,3,Iter3} = gb_trees:next(Iter2).
6> none = gb_trees:next(Iter3).

.fi


.RE
.B
\fBsize(Tree) -> non_neg_integer() when Tree :: tree().\fR

.br
.RS
.PP
Returns the number of nodes in \fITree\fR.

.SS "Examples"

.IP
.nf
1> gb_trees:size(gb_trees:empty()).
0
2> gb_trees:size(gb_trees:from_orddict([{a,1},{b,2}])).
2

.fi


.RE
.B
\fBsmaller(Key1, Tree) -> none | {Key2, Value}\fR
\fB                 when Key1 :: Key, Key2 :: Key, Tree :: tree(Key, Value).\fR

.br
.RS
.PP
Returns \fI{Key2, Value}\fR, where \fIKey2\fR is the greatest key strictly less than \fIKey1\fR, and \fIValue\fR is the value associated with this key.

.PP
Returns \fInone\fR if no such pair exists.

.SS "Examples"

.IP
.nf
1> Tree = gb_trees:from_orddict([{a,1},{b,2},{c,3}]).
2> gb_trees:smaller(c, Tree).
{b,2}
3> gb_trees:smaller(bb, Tree).
{b,2}
4> gb_trees:smaller(a, Tree).
none

.fi


.RE
.B
\fBsmallest(Tree) -> {Key, Value} when Tree :: tree(Key, Value).\fR

.br
.RS
.PP
Returns \fI{Key, Value}\fR, where \fIKey\fR is the smallest key in \fITree\fR, and \fIValue\fR is the value associated with this key.

.PP
Assumes that the tree is not empty.

.SS "Examples"

.IP
.nf
1> Tree = gb_trees:from_orddict([{a,1},{b,2},{c,3}]).
2> gb_trees:smallest(Tree).
{a,1}

.fi


.RE
.B
\fBtake(Key, Tree1) -> {Value, Tree2}\fR
\fB              when\fR
\fB                  Tree1 :: tree(Key, _),\fR
\fB                  Tree2 :: tree(Key, _),\fR
\fB                  Key :: term(),\fR
\fB                  Value :: term().\fR

.br
.RS
.PP
Returns a value \fIValue\fR from node with key \fIKey\fR and new \fITree2\fR with that node removed.

.PP
Assumes that the node with key is present in the tree.

.SS "Examples"

.IP
.nf
1> Tree0 = gb_trees:from_orddict([{a,1},{b,2},{c,3}]).
2> {Value,Tree1} = gb_trees:take(b, Tree0).
3> Value.
2
4> gb_trees:to_list(Tree1).
[{a,1},{c,3}]

.fi


.RE
.B
\fBtake_any(Key, Tree1) -> {Value, Tree2} | error\fR
\fB                  when\fR
\fB                      Tree1 :: tree(Key, _),\fR
\fB                      Tree2 :: tree(Key, _),\fR
\fB                      Key :: term(),\fR
\fB                      Value :: term().\fR

.br
.RS
.PP
Removes the node with key Key from Tree1 if present; otherwise, returns the tree unchanged.

.SS "Examples"

.IP
.nf
1> Tree0 = gb_trees:from_orddict([{a,1},{b,2},{c,3}]).
2> {Value,Tree1} = gb_trees:take_any(b, Tree0).
3> Value.
2
4> gb_trees:to_list(Tree1).
[{a,1},{c,3}]
5> gb_trees:take_any(x, Tree0).
error

.fi


.RE
.B
\fBtake_largest(Tree1) -> {Key, Value, Tree2}\fR
\fB                      when\fR
\fB                          Tree1 :: tree(Key, Value),\fR
\fB                          Tree2 :: tree(Key, Value).\fR

.br
.RS
.PP
Returns \fI{Key, Value, Tree2}\fR, where \fIKey\fR is the largest key in \fITree1\fR, \fIValue\fR is the value associated with this key, and \fITree2\fR is this tree with the corresponding node deleted.

.PP
Assumes that the tree is not empty.

.SS "Examples"

.IP
.nf
1> Tree0 = gb_trees:from_orddict([{a,1},{b,2},{c,3}]).
2> {Key,Value,Tree1} = gb_trees:take_largest(Tree0).
3> Key.
c
4> Value.
3
5> gb_trees:to_list(Tree1).
[{a,1},{b,2}]

.fi


.RE
.B
\fBtake_smallest(Tree1) -> {Key, Value, Tree2}\fR
\fB                       when\fR
\fB                           Tree1 :: tree(Key, Value),\fR
\fB                           Tree2 :: tree(Key, Value).\fR

.br
.RS
.PP
Returns \fI{Key, Value, Tree2}\fR, where Key is the smallest key in \fITree1\fR, \fIValue\fR is the value associated with that key, and \fITree2\fR is the tree with the corresponding node removed.

.PP
Assumes that the tree is not empty.

.SS "Examples"

.IP
.nf
1> Tree0 = gb_trees:from_orddict([{a,1},{b,2},{c,3}]).
2> {Key,Value,Tree1} = gb_trees:take_smallest(Tree0).
3> Key.
a
4> Value.
1
5> gb_trees:to_list(Tree1).
[{b,2},{c,3}]

.fi


.RE
.B
\fBto_list(Tree) -> [{Key, Value}] when Tree :: tree(Key, Value).\fR

.br
.RS
.PP
Converts a tree into an ordered list of key-value tuples.

.SS "Examples"

.IP
.nf
1> Tree = gb_trees:from_orddict([{a,1},{b,2},{c,3}]).
2> gb_trees:to_list(Tree).
[{a,1},{b,2},{c,3}]
3> gb_trees:to_list(gb_trees:empty()).
[]

.fi


.RE
.B
\fBupdate(Key, Value, Tree1) -> Tree2\fR
\fB                when\fR
\fB                    Tree1 :: tree(Key, Value), Tree2 :: tree(Key, Value).\fR

.br
.RS
.PP
Updates \fIKey\fR to value \fIValue\fR in \fITree1\fR and returns the new tree.

.PP
Assumes that the key is present in the tree.

.SS "Examples"

.IP
.nf
1> Tree1 = gb_trees:from_orddict([{a,1},{b,2}]).
2> Tree2 = gb_trees:update(a, 99, Tree1).
3> gb_trees:to_list(Tree2).
[{a,99},{b,2}]

.fi


.RE
.B
\fBvalues(Tree) -> [Value] when Tree :: tree(Key :: term(), Value).\fR

.br
.RS
.PP
Returns the values in \fITree\fR as an ordered list, sorted by their corresponding keys.

.PP
Duplicates are not removed.

.SS "Examples"

.IP
.nf
1> Tree = gb_trees:from_orddict([{a,1},{b,2},{c,3},{d,1}]).
2> gb_trees:values(Tree).
[1,2,3,1]

.fi


.RE
