.TH orddict 3 "stdlib 7.3" "Ericsson AB" "Erlang Module Definition"
.SH NAME
orddict \- Key-value dictionary as ordered list.

.SH DESCRIPTION
.PP
This module provides a \fIKey\fR-\fIValue\fR dictionary. An \fIorddict\fR is a representation of a dictionary, where a list of pairs is used to store the keys and values. The list is ordered after the keys in the Erlang term order.

.PP
This module provides the same interface as the \fIdict\fR module but with a defined representation. One difference is that while \fIdict\fR considers two keys as different if they do not match (\fI=:=\fR), this module considers two keys as different if and only if they do not compare equal (\fI==\fR).

.PP
\fBSee Also\fR

.PP
\fIdict\fR, \fIgb_trees\fR, \fImaps\fR

.SH DATA TYPES
.LP
.B
\fBorddict() :: orddict(_, _).\fR

.br
.RS

.RE
.B
\fBorddict(Key, Value) :: [{Key, Value}].\fR

.br
.RS
.PP
Dictionary as returned by \fInew/0\fR.


.RE
.SH FUNCTIONS
.LP
.B
\fBappend(Key, Value, Orddict1) -> Orddict2\fR
\fB                when\fR
\fB                    Orddict1 :: orddict(Key, Value),\fR
\fB                    Orddict2 :: orddict(Key, Value).\fR

.br
.RS
.PP
Appends a new \fIValue\fR to the current list of values associated with \fIKey\fR.

.PP
An exception is generated if the initial value associated with \fIKey\fR is not a list of values.

.SS "Examples"

.IP
.nf
1> OrdDict1 = orddict:from_list([{x, []}]).
[{x,[]}]
2> OrdDict2 = orddict:append(x, 1, OrdDict1).
[{x,[1]}]
3> OrdDict3 = orddict:append(x, 2, OrdDict2).
[{x,[1,2]}]
4> orddict:append(y, 3, OrdDict3).
[{x,[1,2]},{y,[3]}]

.fi

.IP
.nf
1> OrdDict1 = orddict:from_list([{a, no_list}]).
[{a,no_list}]
2> orddict:append(a, 1, OrdDict1).
** exception error: bad argument
     in operator  ++/2
        called as no_list ++ [1]
     in call from orddict:append/3

.fi


.RE
.B
\fBappend_list(Key, ValList, Orddict1) -> Orddict2\fR
\fB                     when\fR
\fB                         ValList :: [Value],\fR
\fB                         Orddict1 :: orddict(Key, Value),\fR
\fB                         Orddict2 :: orddict(Key, Value).\fR

.br
.RS
.PP
Appends a list of values \fIValList\fR to the current list of values associated with \fIKey\fR.

.PP
An exception is generated if the initial value associated with \fIKey\fR is not a list of values.

.SS "Examples"

.IP
.nf
1> OrdDict1 = orddict:from_list([{x, []}]).
[{x,[]}]
2> OrdDict2 = orddict:append_list(x, [1,2], OrdDict1).
[{x,[1,2]}]
3> OrdDict3 = orddict:append_list(y, [3,4], OrdDict2).
[{x,[1,2]},{y,[3,4]}]

.fi


.RE
.B
\fBerase(Key, Orddict1) -> Orddict2\fR
\fB               when\fR
\fB                   Orddict1 :: orddict(Key, Value),\fR
\fB                   Orddict2 :: orddict(Key, Value).\fR

.br
.RS
.PP
Removes the item with key \fIKey\fR from dictionary \fIOrdDict1\fR.

.SS "Examples"

.IP
.nf
1> OrdDict1 = orddict:from_list([{a, 1}, {b, 2}]).
[{a,1},{b,2}]
2> orddict:erase(a, OrdDict1).
[{b,2}]
3> orddict:erase(z, OrdDict1).
[{a,1},{b,2}]

.fi


.RE
.B
\fBfetch(Key, Orddict) -> Value when Orddict :: orddict(Key, Value).\fR

.br
.RS
.PP
Returns the value associated with \fIKey\fR in dictionary \fIOrddict\fR.

.PP
This function assumes that the \fIKey\fR is present in the dictionary. An exception is generated if \fIKey\fR is not in the dictionary.

.SS "Examples"

.IP
.nf
1> OrdDict1 = orddict:from_list([{a, 1}, {b, 2}]).
[{a,1},{b,2}]
2> orddict:fetch(a, OrdDict1).
1
3> orddict:fetch(missing, OrdDict1).
** exception error: no function clause matching orddict:fetch(missing,[])

.fi


.RE
.B
\fBfetch_keys(Orddict) -> Keys\fR
\fB                    when\fR
\fB                        Orddict :: orddict(Key, Value :: term()),\fR
\fB                        Keys :: [Key].\fR

.br
.RS
.PP
Returns a list of all keys in a dictionary.

.SS "Examples"

.IP
.nf
1> OrdDict1 = orddict:from_list([{a, 1}, {b, 2}]).
[{a,1},{b,2}]
2> orddict:fetch_keys(OrdDict1).
[a,b]

.fi


.RE
.B
\fBfilter(Pred, Orddict1) -> Orddict2\fR
\fB                when\fR
\fB                    Pred :: fun((Key, Value) -> boolean()),\fR
\fB                    Orddict1 :: orddict(Key, Value),\fR
\fB                    Orddict2 :: orddict(Key, Value).\fR

.br
.RS
.PP
\fIOrddict2\fR is a dictionary of all keys and values in \fIOrddict1\fR for which \fIPred(Key, Value)\fR is \fItrue\fR.

.SS "Examples"

.IP
.nf
1> OrdDict1 = orddict:from_list([{a, 1}, {b, 2}]).
[{a,1},{b,2}]
2> orddict:filter(fun (K, V) -> V > 1 end, OrdDict1).
[{b,2}]

.fi


.RE
.B
\fBfind(Key, Orddict) -> {ok, Value} | error\fR
\fB              when Orddict :: orddict(Key, Value).\fR

.br
.RS
.PP
Searches for a key in a dictionary.

.PP
Returns \fI{ok, Value}\fR, where \fIValue\fR is the value associated with \fIKey\fR, or \fIerror\fR if the key is not present in the dictionary.

.SS "Examples"

.IP
.nf
1> OrdDict1 = orddict:from_list([{a, 1}, {b, 2}]).
[{a,1},{b,2}]
2> orddict:find(a, OrdDict1).
{ok,1}
3> orddict:find(c, OrdDict1).
error

.fi


.RE
.B
\fBfold(Fun, Acc0, Orddict) -> Acc1\fR
\fB              when\fR
\fB                  Fun :: fun((Key, Value, AccIn) -> AccOut),\fR
\fB                  Orddict :: orddict(Key, Value),\fR
\fB                  Acc0 :: Acc,\fR
\fB                  Acc1 :: Acc,\fR
\fB                  AccIn :: Acc,\fR
\fB                  AccOut :: Acc.\fR

.br
.RS
.PP
Calls \fIFun\fR on successive keys and values of \fIOrddict\fR together with an extra argument \fIAcc\fR (short for accumulator).

.PP
\fIFun\fR must return a new accumulator that is passed to the next call. \fIAcc0\fR is returned if the list is empty.

.SS "Examples"

.IP
.nf
1> OrdDict1 = orddict:from_list([{a, 1}, {b, 2}]).
[{a,1},{b,2}]
2> orddict:fold(fun (K, V, Acc) -> [{K, V+100} | Acc] end, [], OrdDict1).
[{b,102},{a,101}]

.fi


.RE
.B
\fBfrom_list(List) -> Orddict\fR
\fB                   when\fR
\fB                       List :: [{Key, Value}],\fR
\fB                       Orddict :: orddict(Key, Value).\fR

.br
.RS
.PP
Converts the \fIKey\fR-\fIValue\fR list \fIList\fR to a dictionary.

.SS "Examples"

.IP
.nf
1> OrdDict = orddict:from_list([{2,b},{1,a},{3,c}]).
[{1,a},{2,b},{3,c}]

.fi


.RE
.B
\fBis_empty(Orddict) -> boolean() when Orddict :: orddict().\fR

.br
.RS
.PP
Returns \fItrue\fR if \fIOrddict\fR has no elements; otherwise, returns \fIfalse\fR.

.SS "Examples"

.IP
.nf
1> orddict:is_empty(orddict:new()).
true
2> orddict:is_empty(orddict:from_list([{a,1}])).
false

.fi


.RE
.B
\fBis_key(Key, Orddict) -> boolean()\fR
\fB                when Orddict :: orddict(Key, Value :: term()).\fR

.br
.RS
.PP
Returns \fItrue\fR if \fIKey\fR is contained in dictionary \fIOrddict\fR; otherwise, returns \fIfalse\fR.

.SS "Examples"

.IP
.nf
1> OrdDict = orddict:from_list([{1,a},{2,b},{3,c}]).
[{1,a},{2,b},{3,c}]
2> orddict:is_key(2, OrdDict).
true
3> orddict:is_key(aa, OrdDict).
false

.fi


.RE
.B
\fBmap(Fun, Orddict1) -> Orddict2\fR
\fB             when\fR
\fB                 Fun :: fun((Key, Value1) -> Value2),\fR
\fB                 Orddict1 :: orddict(Key, Value1),\fR
\fB                 Orddict2 :: orddict(Key, Value2).\fR

.br
.RS
.PP
Calls \fIFun\fR on successive keys and values of \fIOrddict1\fR to return a new value for each key.

.SS "Examples"

.IP
.nf
1> OrdDict1 = orddict:from_list([{a, 1}, {b, 2}]).
[{a,1},{b,2}]
2> orddict:map(fun (_K, V) -> V + 100 end, OrdDict1).
[{a,101},{b,102}]

.fi


.RE
.B
\fBmerge(Fun, Orddict1, Orddict2) -> Orddict3\fR
\fB               when\fR
\fB                   Fun :: fun((Key, Value1, Value2) -> Value),\fR
\fB                   Orddict1 :: orddict(Key, Value1),\fR
\fB                   Orddict2 :: orddict(Key, Value2),\fR
\fB                   Orddict3 :: orddict(Key, Value).\fR

.br
.RS
.PP
Merges two dictionaries, \fIOrddict1\fR and \fIOrddict2\fR, to create a new dictionary.

.PP
All the \fIKey\fR-\fIValue\fR pairs from both dictionaries are included in the new dictionary.

.PP
If a key occurs in both dictionaries, \fIFun\fR is called with the key and both values to return a new value.

.PP
\fImerge/3\fR can be defined as follows, but is faster:

.IP
.nf
merge(Fun, D1, D2) ->
    fold(fun (K, V1, D) ->
                 update(K, fun (V2) -> Fun(K, V1, V2) end, V1, D)
         end, D2, D1).

.fi

.SS "Examples"

.IP
.nf
1> OrdDict1 = orddict:from_list([{a, 1}, {b, 2}]).
[{a,1},{b,2}]
2> OrdDict2 = orddict:from_list([{b, 7}, {c, 8}]).
[{b,7},{c,8}]
3> orddict:merge(fun (K, V1, V2) -> V1 * V2 end, OrdDict1, OrdDict2).
[{a,1},{b,14},{c,8}]

.fi


.RE
.B
\fBnew() -> orddict(none(), none()).\fR

.br
.RS
.PP
Creates a new dictionary.

.SS "Examples"

.IP
.nf
1> orddict:new().
[]

.fi


.RE
.B
\fBsize(Orddict) -> non_neg_integer() when Orddict :: orddict().\fR

.br
.RS
.PP
Returns the number of elements in an \fIOrddict\fR.

.SS "Examples"

.IP
.nf
1> orddict:size(orddict:new()).
0
2> orddict:size(orddict:from_list([{a,1},{b,2},{c,3}])).
3

.fi


.RE
.B
\fBstore(Key, Value, Orddict1) -> Orddict2\fR
\fB               when\fR
\fB                   Orddict1 :: orddict(Key, Value),\fR
\fB                   Orddict2 :: orddict(Key, Value).\fR

.br
.RS
.PP
Stores a \fIKey\fR-\fIValue\fR pair in a dictionary.

.PP
If the \fIKey\fR already exists in \fIOrddict1\fR, the associated value is replaced by \fIValue\fR.

.SS "Examples"

.IP
.nf
1> OrdDict1 = orddict:from_list([{a, 1}, {b, 2}]).
[{a,1},{b,2}]
2> orddict:store(a, 99, OrdDict1).
[{a,99},{b,2}]
3> orddict:store(c, 100, OrdDict1).
[{a,1},{b,2},{c,100}]

.fi


.RE
.B
\fBtake(Key, Orddict) -> {Value, Orddict1} | error\fR
\fB              when\fR
\fB                  Orddict :: orddict(Key, Value),\fR
\fB                  Orddict1 :: orddict(Key, Value),\fR
\fB                  Key :: term(),\fR
\fB                  Value :: term().\fR

.br
.RS
.PP
This function returns value from dictionary and new dictionary without this value.

.PP
Returns \fIerror\fR if the key is not present in the dictionary.

.SS "Examples"

.IP
.nf
1> OrdDict1 = orddict:from_list([{a, 1}, {b, 2}]).
[{a,1},{b,2}]
2> orddict:take(a, OrdDict1).
{1,[{b,2}]}
3> orddict:take(missing, OrdDict1).
error

.fi


.RE
.B
\fBto_list(Orddict) -> List\fR
\fB                 when\fR
\fB                     Orddict :: orddict(Key, Value),\fR
\fB                     List :: [{Key, Value}].\fR

.br
.RS
.PP
Converts a dictionary to a list representation.

.SS "Examples"

.IP
.nf
1> OrdDict = orddict:from_list([{2,b},{1,a}]).
[{1,a},{2,b}]
2> orddict:to_list(OrdDict).
[{1,a},{2,b}]

.fi


.RE
.B
\fBupdate(Key, Fun, Orddict1) -> Orddict2\fR
\fB                when\fR
\fB                    Fun :: fun((Value1 :: Value) -> Value2 :: Value),\fR
\fB                    Orddict1 :: orddict(Key, Value),\fR
\fB                    Orddict2 :: orddict(Key, Value).\fR

.br
.RS
.PP
Updates a value in a dictionary by calling \fIFun\fR on the value to get a new value.

.PP
An exception is generated if \fIKey\fR is not present in the dictionary.

.SS "Examples"

.IP
.nf
1> OrdDict1 = orddict:from_list([{a, 1}, {b, 2}]).
[{a,1},{b,2}]
2> orddict:update(a, fun (V) -> V + 100 end, OrdDict1).
[{a,101},{b,2}]

.fi


.RE
.B
\fBupdate(Key, Fun, Initial, Orddict1) -> Orddict2\fR
\fB                when\fR
\fB                    Initial :: Value,\fR
\fB                    Fun :: fun((Value1 :: Value) -> Value2 :: Value),\fR
\fB                    Orddict1 :: orddict(Key, Value),\fR
\fB                    Orddict2 :: orddict(Key, Value).\fR

.br
.RS
.PP
Updates a value in a dictionary by calling \fIFun\fR on the value to get a new value.

.PP
If \fIKey\fR is not present in the dictionary, \fIInitial\fR is stored as the first value.

.PP
For example, \fIappend/3\fR can be defined as follows:

.IP
.nf
append(Key, Val, D) ->
    update(Key, fun (Old) -> Old ++ [Val] end, [Val], D).

.fi

.SS "Examples"

.IP
.nf
1> OrdDict1 = orddict:from_list([{a, 1}, {b, 2}]).
[{a,1},{b,2}]
2> OrdDict2 = orddict:update(c, fun (V) -> V + 100 end, 99, OrdDict1).
[{a,1},{b,2},{c,99}]
3> orddict:update(a, fun (V) -> V + 100 end, 99, OrdDict2).
[{a,101},{b,2},{c,99}]

.fi


.RE
.B
\fBupdate_counter(Key, Increment, Orddict1) -> Orddict2\fR
\fB                        when\fR
\fB                            Orddict1 :: orddict(Key, Value),\fR
\fB                            Orddict2 :: orddict(Key, Value),\fR
\fB                            Increment :: number().\fR

.br
.RS
.PP
Adds \fIIncrement\fR to the value associated with \fIKey\fR and store this value.

.PP
If \fIKey\fR is not present in the dictionary, \fIIncrement\fR is stored as the first value.

.SS "Examples"

.IP
.nf
1> OrdDict1 = orddict:from_list([{a,0},{b,0}]).
[{a,0},{b,0}]
2> OrdDict2 = orddict:update_counter(a, 1, OrdDict1).
[{a,1},{b,0}]
3> OrdDict3 = orddict:update_counter(b, 2, OrdDict2).
[{a,1},{b,2}]
4> orddict:update_counter(z, 7, OrdDict3).
[{a,1},{b,2},{z,7}]

.fi


.RE
