\fB                     {font, wxFont:wxFont()} |\fR
\fB                     {alignment, wx:wx_enum()}.\fR

.br
.RS

.RE
.B
\fBsetAlignment(This, Alignment) -> ok\fR
\fB                      when\fR
\fB                          This :: wxTextAttr(),\fR
