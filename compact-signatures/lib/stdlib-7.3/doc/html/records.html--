    <div class="heading-with-actions">

      <div class="signature-row">

          <h1 class="signature" translate="no">create_options()</h1>


          <span class="note">(not exported)</span>

          <span class="note">(since OTP @OTP-19785@)</span>


          <a href="https://github.com/erlang/otp/blob/master/lib/stdlib/src/records.erl#L52" class="icon-action" rel="help nofollow" aria-label="View Source">
