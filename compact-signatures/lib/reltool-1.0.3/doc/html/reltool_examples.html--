                                           </span><span class="p" data-group-id="8254854028-17">{</span><span class="ss">rel</span><span class="p">,</span><span class="w"> </span><span class="s">&quot;NAME&quot;</span><span class="p">,</span><span class="w"> </span><span class="s">&quot;VSN&quot;</span><span class="p">,</span><span class="w">
                                            </span><span class="p" data-group-id="8254854028-18">[</span><span class="ss">sasl</span><span class="p" data-group-id="8254854028-18">]</span><span class="p">,</span><span class="w">
                                            </span><span class="p" data-group-id="8254854028-19">[</span><span class="p" data-group-id="8254854028-20">{</span><span class="ss">load_dot_erlang</span><span class="p">,</span><span class="w"> </span><span class="ss">false</span><span class="p" data-group-id="8254854028-20">}</span><span class="p" data-group-id="8254854028-19">]</span><span class="p" data-group-id="8254854028-17">}</span><span class="p" data-group-id="8254854028-15">]</span><span class="p" data-group-id="8254854028-14">}</span><span class="p" data-group-id="8254854028-13">}</span><span class="p" data-group-id="8254854028-12">]</span><span class="p" data-group-id="8254854028-11">)</span><span class="p">.</span><span class="w">
