\fB                  Window :: wxWindow:wxWindow() | wxSizer:wxSizer(),\fR
\fB                  Option :: {show, boolean()} | {recursive, boolean()};\fR
\fB          (This, Index, [Option]) -> boolean()\fR
\fB              when\fR
\fB                  This :: wxSizer(),\fR
\fB                  Index :: integer(),\fR
\fB                  Option :: {show, boolean()}.\fR

.br
.RS
.PP
