  <section class="docstring">



        <div class="specs">

            <pre translate="no"><span class="attribute">-type</span> value_type() :: o | i | u | g | s | s | b | ip | op | c32 | c64 | tt.</pre>

        </div>


<ul><li><p><strong><code class="inline">o - 'OBJECT IDENTIFIER'</code></strong></p></li><li><p><strong><code class="inline">i - 'INTEGER'</code></strong></p></li><li><p><strong><code class="inline">u - 'Unsigned32</code></strong></p></li><li><p><strong><code class="inline">g - 'Unsigned32'</code></strong></p></li><li><p><strong><code class="inline">s - 'OCTET STRING'</code></strong></p></li><li><p><strong><code class="inline">b - 'BITS'</code></strong></p></li><li><p><strong><code class="inline">ip - 'IpAddress'</code></strong></p></li><li><p><strong><code class="inline">op - 'Opaque'</code></strong></p></li><li><p><strong><code class="inline">c32 - 'Counter32'</code></strong></p></li><li><p><strong><code class="inline">c64 - 'Counter64'</code></strong></p></li><li><p><strong><code class="inline">tt - 'TimeTicks'</code></strong></p></li></ul>
  </section>
</section>
