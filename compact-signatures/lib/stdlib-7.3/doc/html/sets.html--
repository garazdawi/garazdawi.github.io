</span><span class="gp unselectable">3&gt; </span><span class="n">Mapped</span><span class="w"> </span><span class="o">=</span><span class="w"> </span><span class="nc">sets</span><span class="p">:</span><span class="nf">map</span><span class="p" data-group-id="7321545659-4">(</span><span class="n">F</span><span class="p">,</span><span class="w"> </span><span class="n">S</span><span class="p" data-group-id="7321545659-4">)</span><span class="p">.</span><span class="w">
</span><span class="gp unselectable">4&gt; </span><span class="nc">lists</span><span class="p">:</span><span class="nf">sort</span><span class="p" data-group-id="7321545659-5">(</span><span class="nc">sets</span><span class="p">:</span><span class="nf">to_list</span><span class="p" data-group-id="7321545659-6">(</span><span class="n">Mapped</span><span class="p" data-group-id="7321545659-6">)</span><span class="p" data-group-id="7321545659-5">)</span><span class="p">.</span><span class="w">
</span><span class="p" data-group-id="7321545659-7">[</span><span class="mi">0</span><span class="p">,</span><span class="mi">1</span><span class="p">,</span><span class="mi">2</span><span class="p">,</span><span class="mi">3</span><span class="p" data-group-id="7321545659-7">]</span></code></pre>
