                       NumERR :: <a href="../../../../lib/../erts/doc/html/erlang.html#t:pos_integer/0">pos_integer</a>(),
                       Reason :: <a href="../../../../lib/../erts/doc/html/erlang.html#t:term/0">term</a>();
               (LogDir, Mibs, LogName, LogFile, Start, Stop) -> ok | {ok, Cnt} | {error, Reason}
                   when
                       LogDir :: <a href="snmp.html#t:dir/0">snmp:dir</a>(),
                       Mibs :: [<a href="snmp.html#t:mib_name/0">snmp:mib_name</a>()],
                       LogName :: <a href="../../../../lib/../erts/doc/html/erlang.html#t:string/0">string</a>(),
                       LogFile :: <a href="../../../../lib/../erts/doc/html/erlang.html#t:string/0">string</a>(),
                       Start :: null | <a href="snmp.html#t:log_time/0">snmp:log_time</a>(),
                       Stop :: null | <a href="snmp.html#t:log_time/0">snmp:log_time</a>(),
                       Cnt :: {NumOK, NumERR},
                       NumOK :: <a href="../../../../lib/../erts/doc/html/erlang.html#t:non_neg_integer/0">non_neg_integer</a>(),
                       NumERR :: <a href="../../../../lib/../erts/doc/html/erlang.html#t:pos_integer/0">pos_integer</a>(),
