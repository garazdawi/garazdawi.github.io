.IP \(bu 2.3
.\}.PP
spawn request on the local node.

.RE

.sp
.RS 4
.ie n \{\
\h'-04'\(bu\h'+03'\c
.\}
.el \{\
.sp -1
.IP \(bu 2.3
.\}.PP
spawn request with no options.

.RE


.RE
.B
\fBspawn_request(Node, Fun, Options) -> ReqId\fR
\fB                       when\fR
\fB                           Node :: node(),\fR
\fB                           Fun :: function(),\fR
\fB                           Options :: [Option],\fR
\fB                           Option ::\fR
\fB                               monitor |\fR
\fB                               {monitor, [monitor_option()]} |\fR
