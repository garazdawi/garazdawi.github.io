  <section class="docstring">


        <div class="specs">
          <h4 class="specs-title">Types</h4>

            <pre translate="no">Set1 = Set2 = <a href="#t:set/1">set</a>(Element)</pre>

        </div>


<p>Returns <code class="inline">true</code> when every element of <code class="inline">Set1</code> is also a member of <code class="inline">Set2</code>;
otherwise, returns <code class="inline">false</code>.</p><h2 id="is_subset/2-examples" class="section-heading"><a href="#is_subset/2-examples" class="hover-link"><i class="ri-link-m" aria-hidden="true"></i></a><span class="text">Examples</span></h2><pre><code class="makeup erlang" translate="no"><span class="gp unselectable">1&gt; </span><span class="n">S0</span><span class="w"> </span><span class="o">=</span><span class="w"> </span><span class="nc">sets</span><span class="p">:</span><span class="nf">from_list</span><span class="p" data-group-id="9788390846-1">(</span><span class="p" data-group-id="9788390846-2">[</span><span class="ss">a</span><span class="p">,</span><span class="ss">b</span><span class="p">,</span><span class="ss">c</span><span class="p">,</span><span class="ss">d</span><span class="p" data-group-id="9788390846-2">]</span><span class="p" data-group-id="9788390846-1">)</span><span class="p">.</span><span class="w">
</span><span class="gp unselectable">2&gt; </span><span class="n">S1</span><span class="w"> </span><span class="o">=</span><span class="w"> </span><span class="nc">sets</span><span class="p">:</span><span class="nf">from_list</span><span class="p" data-group-id="9788390846-3">(</span><span class="p" data-group-id="9788390846-4">[</span><span class="ss">c</span><span class="p">,</span><span class="ss">d</span><span class="p" data-group-id="9788390846-4">]</span><span class="p" data-group-id="9788390846-3">)</span><span class="p">.</span><span class="w">
</span><span class="gp unselectable">3&gt; </span><span class="nc">sets</span><span class="p">:</span><span class="nf">is_subset</span><span class="p" data-group-id="9788390846-5">(</span><span class="n">S1</span><span class="p">,</span><span class="w"> </span><span class="n">S0</span><span class="p" data-group-id="9788390846-5">)</span><span class="p">.</span><span class="w">
</span><span class="ss">true</span><span class="w">
</span><span class="gp unselectable">4&gt; </span><span class="nc">sets</span><span class="p">:</span><span class="nf">is_subset</span><span class="p" data-group-id="9788390846-6">(</span><span class="n">S0</span><span class="p">,</span><span class="w"> </span><span class="n">S1</span><span class="p" data-group-id="9788390846-6">)</span><span class="p">.</span><span class="w">
</span><span class="ss">false</span><span class="w">
</span><span class="gp unselectable">5&gt; </span><span class="nc">sets</span><span class="p">:</span><span class="nf">is_subset</span><span class="p" data-group-id="9788390846-7">(</span><span class="n">S0</span><span class="p">,</span><span class="w"> </span><span class="n">S0</span><span class="p" data-group-id="9788390846-7">)</span><span class="p">.</span><span class="w">
</span><span class="ss">true</span></code></pre>
  </section>
</section>
