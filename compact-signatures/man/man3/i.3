.TH i 3 "debugger 6.0.3" "Ericsson AB" "Erlang Module Definition"
.SH NAME
i \- Debugger/Interpreter Interface.

.SH DESCRIPTION
.PP
The \fIi\fR module provides short forms for some of the functions used by the graphical Debugger and some of the functions in module \fIint\fR, the Erlang interpreter.

.PP
This module also provides facilities for displaying status information about interpreted processes and break points.

.PP
It is possible to attach to interpreted processes by only giving the corresponding process identity. By default, an attachment window is displayed. Processes at other Erlang nodes can be attached manually or automatically.

.PP
The functions in this module are defined in the Erlang shell. That is, they can be called without the \fIi:\fR prefix. For example:

.IP
.nf
1> ii(t).
{module,t}
2> iaa([init]).
true

.fi

.SH FUNCTIONS
.LP
.B
\fBhelp() -> ok.\fR

.br
.RS
.PP
Prints help for using the functions in this module.


.RE
.B
\fBia(Pid) -> ok | no_proc when Pid :: pid().\fR

.br
.RS
.PP
Attaches to the debugged process \fIPid\fR.

.PP
An "Attach Process" window is opened for the process.


.RE
.B
\fBia(Pid, Function) -> ok | no_proc\fR
\fB            when\fR
\fB                Pid :: pid(),\fR
\fB                Function :: {Module, Name},\fR
\fB                Module :: module(),\fR
\fB                Name :: atom().\fR

.br
.RS
.PP
Attaches to the debugged process \fIPid\fR.

.PP
The interpreter calls \fIspawn(Module, Name, [Pid])\fR (and ignores the result).


.RE
.B
\fBia(X, Y, Z) -> ok | no_proc\fR
\fB            when X :: integer(), Y :: integer(), Z :: integer().\fR

.br
.RS
.PP
Equivalent to \fIia(Pid)\fR, where \fIPid\fR is the result of calling the shell function \fIpid(X, Y, Z)\fR.


.RE
.B
\fBia(X, Y, Z, Function) -> ok | no_proc\fR
\fB            when\fR
\fB                X :: integer(),\fR
\fB                Y :: integer(),\fR
\fB                Z :: integer(),\fR
\fB                Function :: {Module, Name},\fR
\fB                Module :: module(),\fR
\fB                Name :: atom().\fR

.br
.RS
.PP
Equivalent to \fIia(Pid, Function)\fR, where \fIPid\fR is the result of calling the shell function \fIpid(X, Y, Z)\fR.

.PP
An attached process is expected to call the unofficial function \fIint:attached(Pid)\fR and to be able to handle messages from the interpreter. For an example, see \fIdbg_wx_trace.erl\fR.


.RE
.B
\fBiaa(Flags) -> true when Flags :: [init | break | exit].\fR

.br
.RS
.PP
Sets when to attach to a debugged process automatically.

.PP
Debugger supplies a function that opens "Attach Process" window for the process.

.PP
See int:auto_attach/2 for more information.


.RE
.B
\fBiaa(Flags, Function) -> true\fR
\fB             when\fR
\fB                 Flags :: [init | break | exit],\fR
\fB                 Function :: {Module, Name, Args},\fR
\fB                 Module :: module(),\fR
\fB                 Name :: atom(),\fR
\fB                 Args :: [term()].\fR

.br
.RS
.PP
Sets when and how to attach to a debugged process automatically.

.PP
See int:auto_attach/2 for more information.


.RE
.B
\fBib(Module, Line) -> ok | {error, break_exists}\fR
\fB            when Module :: module(), Line :: integer().\fR

.br
.RS
.PP
Creates a breakpoint at \fILine\fR in \fIModule\fR.


.RE
.B
\fBib(Module, Name, Arity) -> ok | {error, function_not_found}\fR
\fB            when Module :: module(), Name :: atom(), Arity :: integer().\fR

.br
.RS
.PP
Creates breakpoints at the first line of every clause of function \fIModule:Name/Arity\fR.


.RE
.B
\fBiba(Module, Line, Action) -> ok\fR
\fB             when\fR
\fB                 Module :: module(),\fR
\fB                 Line :: integer(),\fR
\fB                 Action :: enable | disable | delete.\fR

.br
.RS
.PP
Sets the trigger action of the breakpoint at \fILine\fR in \fIModule\fR to \fIAction\fR.


.RE
.B
\fBibc(Module, Line, Function) -> ok\fR
\fB             when\fR
\fB                 Module :: module(),\fR
\fB                 Line :: integer(),\fR
\fB                 Function :: {Module, Name},\fR
\fB                 Name :: atom().\fR

.br
.RS
.PP
Sets the conditional test of the breakpoint at \fILine\fR in \fIModule\fR to \fIFunction\fR.

.PP
The conditional test is performed by calling \fIModule:Name(Bindings)\fR, where \fIBindings\fR is the current variable bindings. The function must return \fItrue\fR (break) or \fIfalse\fR (do not break). To retrieve the value of a variable \fIVar\fR use int:get_binding(Var, Bindings).


.RE
.B
\fBibd(Module, Line) -> ok when Module :: module(), Line :: integer().\fR

.br
.RS
.PP
Makes the breakpoint at \fILine\fR in \fIModule\fR inactive.


.RE
.B
\fBibe(Module, Line) -> ok when Module :: module(), Line :: integer().\fR

.br
.RS
.PP
Makes the breakpoint at \fILine\fR in \fIModule\fR active.


.RE
.B
\fBic() -> ok.\fR

.br
.RS
.PP
Clears information about processes executing interpreted code by removing all information about terminated processes.


.RE
.B
\fBii(AbsModules | AbsModule) -> Result\fR
\fB            when\fR
\fB                AbsModules :: [AbsModule, ...],\fR
\fB                AbsModule :: Module | File,\fR
\fB                Module :: module(),\fR
\fB                File :: file:name_all(),\fR
\fB                Result :: AbsModuleResult | AbsModulesResult,\fR
\fB                AbsModuleResult :: {module, Module} | error,\fR
\fB                AbsModulesResult :: ok.\fR

.br
.RS
.PP
Interprets the specified module(s) on the local node.


.sp
.RS 4
.ie n \{\
\h'-04'\(bu\h'+03'\c
.\}
.el \{\
.sp -1
.IP \(bu 2.3
.\}.PP
If \fIAbsModule :: Module | File\fR, then \fIResult :: {module, Module} | error\fR.

.RE

.sp
.RS 4
.ie n \{\
\h'-04'\(bu\h'+03'\c
.\}
.el \{\
.sp -1
.IP \(bu 2.3
.\}.PP
If \fIAbsModules :: [AbsModule]\fR, then \fIResult :: ok\fR.

.RE

.PP
See \fIint:i/1\fR for more information.


.RE
.B
\fBil() -> ok.\fR

.br
.RS
.PP
Makes a printout of all interpreted modules.

.PP
Modules are printed together with the full path name of the corresponding source code file.


.RE
.B
\fBim() -> pid().\fR

.br
.RS
.PP
Starts a new graphical Monitor window.

.PP
This is the Monitor window, the main window of Debugger. All the Debugger and interpreter functionality is accessed from the Monitor window. This window displays the status of all processes that have been or are executing interpreted modules.


.RE
.B
\fBini(AbsModules | AbsModule) -> Result\fR
\fB             when\fR
\fB                 AbsModules :: [AbsModule],\fR
\fB                 AbsModule :: Module | File,\fR
\fB                 Module :: module(),\fR
\fB                 File :: file:name_all(),\fR
\fB                 Result :: AbsModuleResult | AbsModulesResult,\fR
\fB                 AbsModuleResult :: {module, Module} | error,\fR
\fB                 AbsModulesResult :: ok.\fR

.br
.RS
.PP
Interprets the specified module(s) on all known nodes.


.sp
.RS 4
.ie n \{\
\h'-04'\(bu\h'+03'\c
.\}
.el \{\
.sp -1
.IP \(bu 2.3
.\}.PP
If \fIAbsModule :: Module | File\fR, then \fIResult :: {module, Module} | error\fR.

.RE

.sp
.RS 4
.ie n \{\
\h'-04'\(bu\h'+03'\c
.\}
.el \{\
.sp -1
.IP \(bu 2.3
.\}.PP
If \fIAbsModules :: [AbsModule]\fR, then \fIResult :: ok\fR.

.RE

.PP
See \fIint:ni/1\fR for more information.


.RE
.B
\fBinq(AbsModule) -> ok\fR
\fB             when\fR
\fB                 AbsModule :: Module | File,\fR
\fB                 Module :: module(),\fR
\fB                 File :: file:name_all().\fR

.br
.RS
.PP
Stops interpreting the specified module on all known nodes.


.RE
.B
\fBip() -> ok.\fR

.br
.RS
.PP
Prints the current status of all interpreted processes.


.RE
.B
\fBipb() -> ok.\fR

.br
.RS
.PP
Prints all existing breakpoints.


.RE
.B
\fBipb(Module) -> ok when Module :: module().\fR

.br
.RS
.PP
Prints all existing breakpoints in \fIModule\fR.


.RE
.B
\fBiq(AbsModule) -> ok\fR
\fB            when\fR
\fB                AbsModule :: Module | File,\fR
\fB                Module :: module(),\fR
\fB                File :: file:name_all().\fR

.br
.RS
.PP
Stops interpreting the specified module on the local node.


.RE
.B
\fBir() -> ok.\fR

.br
.RS
.PP
Deletes all breakpoints in all interpreted modules.


.RE
.B
\fBir(Module) -> ok when Module :: module().\fR

.br
.RS
.PP
Deletes all breakpoints in \fIModule\fR.


.RE
.B
\fBir(Module, Line) -> ok when Module :: module(), Line :: integer().\fR

.br
.RS
.PP
Deletes the breakpoint at \fILine\fR in \fIModule\fR.


.RE
.B
\fBir(Module, Name, Arity) -> ok | {error, function_not_found}\fR
\fB            when Module :: module(), Name :: atom(), Arity :: integer().\fR

.br
.RS
.PP
Deletes the breakpoints at the first line of every clause of function \fIModule:Name/Arity\fR.


.RE
.B
\fBist(Flag) -> true when Flag :: all | no_tail | false.\fR

.br
.RS
.PP
Sets how to save call frames in the stack.

.PP
See int:stack_trace/1 for more information.


.RE
.B
\fBiv() -> atom().\fR

.br
.RS
.PP
Returns the current version of the interpreter (Debugger).


.RE
