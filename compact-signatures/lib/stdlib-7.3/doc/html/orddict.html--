            <h1 class="signature" translate="no">append(Orddict1 :: <a href="#t:orddict/2">orddict</a>(Key, Value))<span class="signature-arrow">&nbsp;-&gt;&nbsp;</span><span class="signature-result">Orddict2</span></h1>




          <a href="https://github.com/erlang/otp/blob/master/lib/stdlib/src/orddict.erl#L358" class="icon-action" rel="help nofollow" aria-label="View Source">
