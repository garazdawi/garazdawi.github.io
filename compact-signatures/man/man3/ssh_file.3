.B
\fBdecode(SshBin, Type) -> Decoded | {error, term()}\fR
\fB                when\fR
\fB                    SshBin :: binary(),\fR
\fB                    Type ::\fR
\fB                        ssh2_pubkey | public_key | openssh_key |\fR
\fB                        rfc4716_key | openssh_key_v1 | known_hosts |\fR
\fB                        auth_keys,\fR
\fB                    Decoded ::\fR
\fB                        Decoded_ssh2_pubkey | Decoded_public |\fR
\fB                        Decoded_openssh | Decoded_rfc4716 |\fR
\fB                        Decoded_openssh_key_v1 | Decoded_known_hosts |\fR
\fB                        Decoded_auth_keys,\fR
\fB                    Decoded_ssh2_pubkey :: public_key:public_key(),\fR
\fB                    Decoded_public ::\fR
\fB                        Decoded_rfc4716 | Decoded_openssh_key_v1 |\fR
\fB                        Decoded_openssh,\fR
\fB                    Decoded_openssh ::\fR
\fB                        [{public_key:public_key(),\fR
\fB                          [{comment, string()}]}],\fR
\fB                    Decoded_rfc4716 :: [{key(), [{headers, Attrs}]}],\fR
\fB                    Decoded_openssh_key_v1 ::\fR
\fB                        experimental_openssh_key_v1_decode(),\fR
