        <div class="specs">
          <h4 class="specs-title">Types</h4>

            <pre translate="no">Fname = Rest = <a href="../../../../lib/../erts/doc/html/erlang.html#t:string/0">string</a>()</pre>

            <pre translate="no">CallBackModule = <a href="../../../../lib/../erts/doc/html/erlang.html#t:module/0">module</a>()</pre>

