            <h1 class="signature" translate="no">get_event_mgr_ref()<span class="signature-arrow">&nbsp;-&gt;&nbsp;</span><span class="signature-result"><a href="../../../../lib/../erts/doc/html/erlang.html#t:atom/0">atom</a>()</span></h1>



