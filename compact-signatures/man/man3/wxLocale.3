.B
\fBaddCatalog(This, Domain) -> boolean()\fR
\fB                    when\fR
\fB                        This :: wxLocale(), Domain :: unicode:chardata().\fR

.br
.RS
.PP
Calls wxTranslations::AddCatalog(const wxString&).


.RE
.B
\fBaddCatalog(This, Domain, MsgIdLanguage) -> boolean()\fR
\fB                    when\fR
\fB                        This :: wxLocale(),\fR
