.RE
.B
\fBstandard_entry(Tag, Val) -> StandardEntry\fR
\fB                        when\fR
\fB                            Tag ::\fR
\fB                                sysDescr | sysObjectID | sysContact |\fR
\fB                                sysName | sysLocation | sysServices |\fR
\fB                                snmpEnableAuthenTraps,\fR
\fB                            Val :: term(),\fR
\fB                            StandardEntry :: standard_entry().\fR

.br
.RS
.PP
Create an entry for the agent standard config file, \fIstandard.conf\fR.

.PP
The type of \fIVal\fR depends on the value of \fITag\fR:

sysDescr: string() <mandatory>
.RS 2

\fIDisplayString (SIZE(0..255))\fR

.RE

sysObjectID: snmp:oid() <mandatory>
.RS 2

\fIOBJECT IDENTIFIER\fR

.RE

sysContact: string() <mandatory>
.RS 2

\fIDisplayString (SIZE(0..255))\fR

.RE

sysName: string() <mandatory>
.RS 2

\fIDisplayString (SIZE(0..255))\fR

.RE

sysLocation: string() <mandatory>
.RS 2

\fIDisplayString (SIZE(0..255))\fR

.RE

sysLocation: non_neg_integer() <mandatory>
.RS 2
"A value which indicates the set of services that this entity primarily offers."

.PP
\fIINTEGER (0..127)\fR


.RE

snmpEnableAuthenTraps: enabled | disabled <mandatory>
.RS 2

\fIINTEGER { enabled(1), disabled(2) }\fR

.RE

.PP
See System Information for more info.


.RE
.B
\fBtarget_addr_entry(Name, Domain, Addr, TagList, ParamsName,\fR
\fB                        EngineId) ->\fR
\fB                           TargetAddrEntry\fR
\fB                           when\fR
\fB                               Name :: snmp_target_mib:name(),\fR
\fB                               Domain :: transportDomain(),\fR
\fB                               Addr :: transportAddress(),\fR
\fB                               TagList :: snmp_target_mib:tag_list(),\fR
\fB                               ParamsName :: snmp_target_mib:params(),\fR
\fB                               EngineId ::\fR
\fB                                   snmp_framework_mib:engine_id(),\fR
\fB                               TargetAddrEntry :: target_addr_entry();\fR
\fB                       (Name, IP, TagList, ParamsName, EngineId, TMask) ->\fR
\fB                           TargetAddrEntry\fR
\fB                           when\fR
\fB                               Name :: snmp_target_mib:name(),\fR
\fB                               IP :: inet:ip_address(),\fR
\fB                               TagList :: snmp_target_mib:tag_list(),\fR
\fB                               ParamsName :: snmp_target_mib:params(),\fR
\fB                               EngineId ::\fR
\fB                                   snmp_framework_mib:engine_id(),\fR
\fB                               TMask :: snmp_target_mib:tmask(),\fR
\fB                               TargetAddrEntry :: target_addr_entry().\fR

.br
.RS
.PP
Create an entry for the agent target_addr config file, \fItarget_addr.conf\fR.

.PP
\fIName\fR must be a \fInon-empty\fR string.

.PP
\fItarget_addr_entry/6\fR (1) translates to the following call: \fItarget_addr_entry(Name, Domain, Addr, TagList, ParamsName, EngineId, [])\fR.

.PP
\fItarget_addr_entry/6\fR (2) translates to the following call (with \fIDomain\fR and \fIAddr\fR built from \fIIP\fR and the default port number): \fItarget_addr_entry(Name, Domain, Addr, TagList, ParamsName, EngineId, TMask, 2048)\fR.

.PP
See Target Address Definitions for more info.


.RE
.B
\fBtarget_addr_entry(Name, Domain, Addr, TagList, ParamsName,\fR
\fB                        EngineId, TMask) ->\fR
\fB                           TargetAddrEntry\fR
\fB                           when\fR
\fB                               Name :: snmp_target_mib:name(),\fR
\fB                               Domain :: transportDomain(),\fR
\fB                               Addr :: transportAddress(),\fR
\fB                               TagList :: snmp_target_mib:tag_list(),\fR
\fB                               ParamsName :: snmp_target_mib:params(),\fR
\fB                               EngineId ::\fR
\fB                                   snmp_framework_mib:engine_id(),\fR
\fB                               TMask :: snmp_target_mib:tmask(),\fR
\fB                               TargetAddrEntry :: target_addr_entry();\fR
\fB                       (Name, IP, Port, TagList, ParamsName, EngineId,\fR
\fB                        TMask) ->\fR
\fB                           TargetAddrEntry\fR
\fB                           when\fR
\fB                               Name :: snmp_target_mib:name(),\fR
\fB                               IP :: inet:ip_address(),\fR
\fB                               Port :: inet:port_number(),\fR
\fB                               TagList :: snmp_target_mib:tag_list(),\fR
\fB                               ParamsName :: snmp_target_mib:params(),\fR
\fB                               EngineId ::\fR
\fB                                   snmp_framework_mib:engine_id(),\fR
\fB                               TMask :: snmp_target_mib:tmask(),\fR
\fB                               TargetAddrEntry :: target_addr_entry().\fR

.br
.RS
.PP
Create an entry for the agent target_addr config file, \fItarget_addr.conf\fR.

.PP
