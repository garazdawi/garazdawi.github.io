            <h1 class="signature" translate="no">from_orddict(Orddict :: <a href="#t:indx_pairs/1">indx_pairs</a>(Value :: Type))<span class="signature-arrow">&nbsp;-&gt;&nbsp;</span><span class="signature-result"><a href="#t:array/1">array</a>(Type)</span></h1>




          <a href="https://github.com/erlang/otp/blob/master/lib/stdlib/src/array.erl#L1321" class="icon-action" rel="help nofollow" aria-label="View Source">
            <i class="ri-code-s-slash-line" aria-hidden="true"></i>
          </a>

      </div>
    </div>
  </div>

