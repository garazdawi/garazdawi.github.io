              <h1 class="signature" translate="no">mapfoldr(Low, High, Function, InitialAcc, Array)<span class="signature-arrow">&nbsp;-&gt;&nbsp;</span><span class="signature-result">{<a href="#t:array/1">array</a>(Type), A}</span></h1>




