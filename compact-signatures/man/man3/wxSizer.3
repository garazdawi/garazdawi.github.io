\fB                  Window :: wxWindow:wxWindow() | wxSizer:wxSizer();\fR
\fB          (This, Index) -> boolean()\fR
\fB              when This :: wxSizer(), Index :: integer();\fR
\fB          (This, Show) -> ok when This :: wxSizer(), Show :: boolean().\fR

.br
.RS

.RE
