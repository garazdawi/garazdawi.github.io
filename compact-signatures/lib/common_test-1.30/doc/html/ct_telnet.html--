    </a>
    <div class="heading-with-actions">

        <div class="signature-row">
          <h1 class="signature" translate="no">sendf(Connection, CmdFormat, Args)<span class="signature-arrow">&nbsp;≡&nbsp;</span><span class="signature-result">sendf(Connection, CmdFormat, Args, [])</span></h1>


            <a href="https://github.com/erlang/otp/blob/master/lib/common_test/src/ct_telnet.erl#L521" class="icon-action" rel="help nofollow" aria-label="View Source">
