<p>Equivalent to <a href="../../../../lib/../erts/doc/html/erlang.html#t:spawn_opt_option/0"><code class="inline">erlang:spawn_opt_option/0</code></a>.</p>
  </section>
</section>
<section class="detail" id="t:start_spawn_option/0">


  <div class="detail-header">
    <a href="#t:start_spawn_option/0" class="detail-link" data-no-tooltip="" aria-label="Link to this type">
      <i class="ri-link-m" aria-hidden="true"></i>
    </a>
    <div class="heading-with-actions">

      <div class="signature-row">

          <h1 class="signature" translate="no">start_spawn_option()</h1>



          <a href="https://github.com/erlang/otp/blob/master/lib/stdlib/src/proc_lib.erl#L101" class="icon-action" rel="help nofollow" aria-label="View Source">
            <i class="ri-code-s-slash-line" aria-hidden="true"></i>
          </a>

      </div>
    </div>
  </div>

  <section class="docstring">



        <div class="specs">

            <pre translate="no"><span class="attribute">-type</span> start_spawn_option() ::
          link |
          {priority, <a href="../../../../lib/../erts/doc/html/erlang.html#t:priority_level/0">erlang:priority_level</a>()} |
          {fullsweep_after, <a href="../../../../lib/../erts/doc/html/erlang.html#t:non_neg_integer/0">non_neg_integer</a>()} |
          {min_heap_size, <a href="../../../../lib/../erts/doc/html/erlang.html#t:non_neg_integer/0">non_neg_integer</a>()} |
          {min_bin_vheap_size, <a href="../../../../lib/../erts/doc/html/erlang.html#t:non_neg_integer/0">non_neg_integer</a>()} |
          {max_heap_size, <a href="../../../../lib/../erts/doc/html/erlang.html#t:max_heap_size/0">erlang:max_heap_size</a>()} |
          {message_queue_data, <a href="../../../../lib/../erts/doc/html/erlang.html#t:message_queue_data/0">erlang:message_queue_data</a>()}.</pre>

        </div>


<p>A restricted set of <a href="#t:spawn_option/0">spawn options</a>. Most notably <code class="inline">monitor</code>
is <em>not</em> part of these options.</p>
  </section>
</section>

    </div>
  </section>

