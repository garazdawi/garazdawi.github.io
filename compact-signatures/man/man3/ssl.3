.RE
.B
\fBexport_key_materials(SslSocket, Labels, Contexts, WantedLengths,\fR
\fB                           ConsumeSecret) ->\fR
\fB                              {ok, ExportKeyMaterials} |\fR
\fB                              {error,\fR
\fB                               exporter_master_secret_already_consumed |\fR
\fB                               bad_input}\fR
\fB                              when\fR
\fB                                  SslSocket :: sslsocket(),\fR
\fB                                  Labels :: [binary()],\fR
\fB                                  Contexts :: [binary() | no_context],\fR
