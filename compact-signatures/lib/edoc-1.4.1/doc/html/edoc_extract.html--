<div id="top-content">
  <div class="heading-with-actions top-heading">
    <h1>
      <span translate="no">edoc_extract</span> 
      <small class="app-vsn" translate="no">(edoc v1.4.1)</small>

    </h1>


      <a href="https://github.com/erlang/otp/blob/master/lib/edoc/src/edoc_extract.erl#L40" title="View Source" class="icon-action" rel="help nofollow">
        <i class="ri-code-s-slash-line" aria-hidden="true"></i>
        <span class="sr-only">View Source</span>
      </a>

  </div>


    <section id="moduledoc">
<p>EDoc documentation extraction.</p><p><em>See also: </em><a href="edoc.html">edoc</a>.</p>
    </section>

</div>

