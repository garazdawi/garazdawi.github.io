            <pre translate="no">Name = <a href="../../../../lib/../erts/doc/html/erlang.html#t:atom/0">atom</a>()</pre>

            <pre translate="no">ConnType = <a href="#t:connection_type/0">connection_type</a>()</pre>

            <pre translate="no">Result = {ok, Handle} | {error, Reason}</pre>

            <pre translate="no">Reason = <a href="../../../../lib/../erts/doc/html/erlang.html#t:term/0">term</a>()</pre>

            <pre translate="no">Handle = <a href="#t:handle/0">handle</a>()</pre>

        </div>


<p>Opens a Telnet connection to the specified target host.</p>
  </section>
