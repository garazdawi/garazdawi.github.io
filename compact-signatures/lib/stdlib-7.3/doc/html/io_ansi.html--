            <h1 class="signature" translate="no">color(Index :: 0..255 | 0..87 | <a href="#t:color_atom/0">color_atom</a>())<span class="signature-arrow">&nbsp;-&gt;&nbsp;</span><span class="signature-result"><a href="unicode.html#t:chardata/0">unicode:chardata</a>()</span></h1>



