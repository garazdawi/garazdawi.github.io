</span><span class="gp unselectable">2&gt; </span><span class="nc">array</span><span class="p">:</span><span class="nf">to_list</span><span class="p" data-group-id="5305899635-3">(</span><span class="n">A</span><span class="p" data-group-id="5305899635-3">)</span><span class="p">.</span><span class="w">
