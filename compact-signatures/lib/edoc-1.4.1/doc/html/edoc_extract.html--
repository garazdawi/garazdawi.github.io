          <a href="https://github.com/erlang/otp/blob/master/lib/edoc/src/edoc_extract.erl#L94" class="icon-action" rel="help nofollow" aria-label="View Source">
            <i class="ri-code-s-slash-line" aria-hidden="true"></i>
          </a>

      </div>
