</span><span class="gp unselectable">4&gt; </span><span class="nc">lists</span><span class="p">:</span><span class="nf">sort</span><span class="p" data-group-id="3462941677-9">(</span><span class="nc">sets</span><span class="p">:</span><span class="nf">to_list</span><span class="p" data-group-id="3462941677-10">(</span><span class="nc">sets</span><span class="p">:</span><span class="nf">subtract</span><span class="p" data-group-id="3462941677-11">(</span><span class="n">S1</span><span class="p">,</span><span class="w"> </span><span class="n">S0</span><span class="p" data-group-id="3462941677-11">)</span><span class="p" data-group-id="3462941677-10">)</span><span class="p" data-group-id="3462941677-9">)</span><span class="p">.</span><span class="w">
