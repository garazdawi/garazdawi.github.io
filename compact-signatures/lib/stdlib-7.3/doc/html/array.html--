  <div class="heading-with-actions top-heading">
    <h1>
      <span translate="no">array</span> 
      <small class="app-vsn" translate="no">(stdlib v7.3)</small>

    </h1>

<a href="array.md" title="Copy Markdown (hold Ctrl/Cmd and click it to open as Markdown)" class="copy-markdown icon-action" rel="help">
  <i class="ri-markdown-line" aria-hidden="true"></i>
  <span class="sr-only">Copy Markdown</span>
</a>



      <a href="https://github.com/erlang/otp/blob/master/lib/stdlib/src/array.erl#L23" title="View Source" class="icon-action" rel="help nofollow">
