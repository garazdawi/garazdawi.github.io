.B
\fBsetFontFamily(This, Family) -> ok\fR
\fB                       when This :: wxTextAttr(), Family :: wx:wx_enum().\fR

.br
.RS
.PP
Sets the font family.


.RE
.B
\fBsetFontPixelSize(This, PixelSize) -> ok\fR
\fB                          when\fR
\fB                              This :: wxTextAttr(),\fR
\fB                              PixelSize :: integer().\fR

.br
.RS
.PP
Sets the font size in pixels.


.RE
.B
\fBsetFontPointSize(This, PointSize) -> ok\fR
\fB                          when\fR
\fB                              This :: wxTextAttr(),\fR
\fB                              PointSize :: integer().\fR

.br
.RS
.PP
Sets the font size in points.


.RE
.B
\fBsetFontSize(This, PointSize) -> ok\fR
\fB                     when This :: wxTextAttr(), PointSize :: integer().\fR

.br
.RS
.PP
Sets the font size in points.


.RE
.B
\fBsetFontStyle(This, FontStyle) -> ok\fR
\fB                      when\fR
\fB                          This :: wxTextAttr(),\fR
\fB                          FontStyle :: wx:wx_enum().\fR

.br
.RS
